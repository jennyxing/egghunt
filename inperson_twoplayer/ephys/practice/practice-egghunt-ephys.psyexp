        <Param val="instr_computer.bold = true;&amp;#10;agent2_indicator_text.color = &quot;red&quot;;&amp;#10;timer1 = new core.Clock();&amp;#10;count1_comp += 1;&amp;#10;if ((count1_comp === 1)) {&amp;#10;    x_shift = 0.15;&amp;#10;    y_shift = 0;&amp;#10;    this_comp_move_1 = &quot;right&quot;;&amp;#10;    this_comp_instr_txt = &quot;It is the other player's turn now&quot;;&amp;#10;} else {&amp;#10;    if ((count1_comp === 2)) {&amp;#10;        x_shift = 0;&amp;#10;        y_shift = (- 0.15);&amp;#10;        this_comp_move_1 = &quot;down&quot;;&amp;#10;        this_comp_instr_txt = &quot;It is the other player's turn now&quot;;&amp;#10;    } else {&amp;#10;        if ((count1_comp === 3)) {&amp;#10;            x_shift = 0;&amp;#10;            y_shift = (- 0.15);&amp;#10;            this_comp_move_1 = &quot;down&quot;;&amp;#10;            this_comp_instr_txt = &quot;It is the other player's turn now&quot;;&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="instr_computer.bold = True&amp;#10;agent2_indicator_text.color = &quot;red&quot;&amp;#10;timer1 = core.Clock()&amp;#10;&amp;#10;count1_comp += 1&amp;#10;if count1_comp == 1:&amp;#10;    # right&amp;#10;    x_shift = .15&amp;#10;    y_shift = 0&amp;#10;    this_comp_move_1 = 'right'&amp;#10;    this_comp_instr_txt = 'It is the other player\'s turn now'&amp;#10;elif count1_comp == 2:&amp;#10;    # down&amp;#10;    x_shift = 0&amp;#10;    y_shift = -.15&amp;#10;    this_comp_move_1 = 'down'&amp;#10;    this_comp_instr_txt = 'It is the other player\'s turn now'&amp;#10;elif count1_comp == 3:&amp;#10;    # down&amp;#10;    x_shift = 0&amp;#10;    y_shift = -.15&amp;#10;    this_comp_move_1 = 'down'&amp;#10;    this_comp_instr_txt = 'It is the other player\'s turn now'&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
