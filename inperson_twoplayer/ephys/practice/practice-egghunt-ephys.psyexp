        <Param val="#GridWorldComponents = [b_0_2, b_0_1, b_3_0, b_2_2, b_1_2, b_2_1, b_2_neg1, b_2_neg2, b_2_0, b_1_neg2, b_1_0, b_0_0, b_neg1_0, b_neg1_2, b_neg1_neg2, b_neg2_0, b_neg2_1, b_neg2_neg1, b_neg2_neg2, b_neg2_2, b_neg3_0, b_0_neg1, b_0_neg2, rabbit_left, rabbit_right]&amp;#10;#&amp;#10;#for thisComponent in GridWorldComponents:&amp;#10;#    if hasattr(thisComponent, &quot;setAutoDraw&quot;):&amp;#10;#        thisComponent.setAutoDraw(True)&amp;#10;#&amp;#10;#AgentsComponents = [agent2, chick1]&amp;#10;#if nchicks &gt;= 2:&amp;#10;#    AgentsComponents += [chick2]&amp;#10;#&amp;#10;#if nchicks &gt;= 3:&amp;#10;#    AgentsComponents += [chick3]&amp;#10;#    &amp;#10;#for thisComponent in AgentsComponents:&amp;#10;#    if hasattr(thisComponent, &quot;setAutoDraw&quot;):&amp;#10;#        thisComponent.setAutoDraw(True)" valType="extendedCode" updates="constant" name="End Routine"/>
