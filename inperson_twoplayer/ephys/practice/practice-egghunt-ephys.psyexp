      <CodeComponent name="change_computer_4">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="count4_comp = 0" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="count4_comp = 0;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="instr_computer_4.bold = true;&amp;#10;agent2_indicator_text.color = &quot;red&quot;;&amp;#10;timer4 = new core.Clock();&amp;#10;count4_comp += 1;&amp;#10;if ((count4_comp === 1)) {&amp;#10;    x_shift = 0;&amp;#10;    y_shift = (- 0.15);&amp;#10;    this_comp_move_4 = &quot;down&quot;;&amp;#10;    this_comp_instr_txt = &quot;It is the other player's turn now&quot;;&amp;#10;} else {&amp;#10;    if ((count4_comp === 2)) {&amp;#10;        x_shift = 0;&amp;#10;        y_shift = (- 0.15);&amp;#10;        this_comp_move_4 = &quot;down&quot;;&amp;#10;        this_comp_instr_txt = &quot;It is the other player's turn now, but they can't catch the chicken yet&quot;;&amp;#10;    } else {&amp;#10;        if ((count4_comp === 3)) {&amp;#10;            x_shift = 0;&amp;#10;            y_shift = (- 0.15);&amp;#10;            this_comp_move_4 = &quot;down&quot;;&amp;#10;            this_comp_instr_txt = &quot;Now the other player can catch the chicken with you&quot;;&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="instr_computer_4.bold = True&amp;#10;agent2_indicator_text.color = &quot;red&quot;&amp;#10;timer4 = core.Clock()&amp;#10;&amp;#10;count4_comp += 1&amp;#10;if count4_comp == 1:&amp;#10;    # down&amp;#10;    x_shift = 0&amp;#10;    y_shift = -.15&amp;#10;    this_comp_move_4 = 'down'&amp;#10;    this_comp_instr_txt = 'It is the other player\'s turn now'&amp;#10;elif count4_comp == 2:&amp;#10;    # down&amp;#10;    x_shift = 0&amp;#10;    y_shift = -.15&amp;#10;    this_comp_move_4 = 'down'&amp;#10;    this_comp_instr_txt = 'It is the other player\'s turn now, but they can\'t catch the chicken yet'&amp;#10;elif count4_comp == 3:&amp;#10;    # down&amp;#10;    x_shift = 0&amp;#10;    y_shift = -.15&amp;#10;    this_comp_move_4 = 'down'&amp;#10;    this_comp_instr_txt = 'Now the other player can catch the chicken with you'&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="if timer4.getTime()&gt;2:&amp;#10;    &amp;#10;    agent2.image = agent2_imgs[this_comp_move_4]&amp;#10;    agent2_pos = [agent2_pos[0]+x_shift, agent2_pos[1]+y_shift]&amp;#10;    agent2.setPos(agent2_pos, log=True)&amp;#10;    agent2_indicator_text.setPos(agent2_pos, log=True)&amp;#10;&amp;#10;    win.flip()&amp;#10;    core.wait(1)&amp;#10;&amp;#10;    agent2.image = agent2_imgs['down']&amp;#10;    win.flip()&amp;#10;    continueRoutine = False&amp;#10;    " valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="if ((timer4.getTime() &gt; 2)) {&amp;#10;    agent2.image = agent2_imgs[this_comp_move_4];&amp;#10;    agent2_pos = [(agent2_pos[0] + x_shift), (agent2_pos[1] + y_shift)];&amp;#10;    agent2.setPos(agent2_pos, {&quot;log&quot;: true});&amp;#10;    agent2_indicator_text.setPos(agent2_pos, {&quot;log&quot;: true});&amp;#10;    psychoJS.window.flip();&amp;#10;    core.wait(1);&amp;#10;    agent2.image = agent2_imgs[&quot;down&quot;];&amp;#10;    psychoJS.window.flip();&amp;#10;    continueRoutine = false;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="this_comp_instr_txt = &quot;You caught the chicken&quot;;&amp;#10;psychoJS.window.flip();&amp;#10;agent2_indicator_text.color = &quot;black&quot;;&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="this_comp_instr_txt = 'You caught the chicken'&amp;#10;win.flip()&amp;#10;agent2_indicator_text.color = &quot;black&quot;" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="change_computer_4" valType="code" updates="None" name="name"/>
      </CodeComponent>
