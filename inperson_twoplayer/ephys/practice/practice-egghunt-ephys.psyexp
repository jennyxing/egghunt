        <Param val="var _pj;&amp;#10;function _pj_snippets(container) {&amp;#10;    function in_es6(left, right) {&amp;#10;        if (((right instanceof Array) || ((typeof right) === &quot;string&quot;))) {&amp;#10;            return (right.indexOf(left) &gt; (- 1));&amp;#10;        } else {&amp;#10;            if (((right instanceof Map) || (right instanceof Set) || (right instanceof WeakMap) || (right instanceof WeakSet))) {&amp;#10;                return right.has(left);&amp;#10;            } else {&amp;#10;                return (left in right);&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    container[&quot;in_es6&quot;] = in_es6;&amp;#10;    return container;&amp;#10;}&amp;#10;_pj = {};&amp;#10;_pj_snippets(_pj);&amp;#10;current_agent1_keyresp = resp_agent1.getKeys({&quot;clear&quot;: true});&amp;#10;if ((resp_agent1.keys === &quot;escape&quot;)) {&amp;#10;    core.quit();&amp;#10;}&amp;#10;if (current_agent1_keyresp) {&amp;#10;    if (_pj.in_es6(resp_agent1.keys, possiblemoves)) {&amp;#10;        if (((resp_agent1.keys === &quot;h&quot;) || (resp_agent1.keys === &quot;num_4&quot;))) {&amp;#10;            this_agent1_move = &quot;left&quot;;&amp;#10;            agent1_pos = [(agent1_pos[0] - 0.15), agent1_pos[1]];&amp;#10;            agent1.image = agent1_imgs[&quot;left&quot;];&amp;#10;            psychoJS.window.flip();&amp;#10;        } else {&amp;#10;            if (((resp_agent1.keys === &quot;k&quot;) || (resp_agent1.keys === &quot;num_6&quot;))) {&amp;#10;                this_agent1_move = &quot;right&quot;;&amp;#10;                agent1_pos = [(agent1_pos[0] + 0.15), agent1_pos[1]];&amp;#10;                agent1.image = agent1_imgs[&quot;right&quot;];&amp;#10;                psychoJS.window.flip();&amp;#10;            } else {&amp;#10;                if (((resp_agent1.keys === &quot;u&quot;) || (resp_agent1.keys === &quot;num_8&quot;))) {&amp;#10;                    this_agent1_move = &quot;up&quot;;&amp;#10;                    agent1_pos = [agent1_pos[0], (agent1_pos[1] + 0.15)];&amp;#10;                    agent1.image = agent1_imgs[&quot;up&quot;];&amp;#10;                    psychoJS.window.flip();&amp;#10;                } else {&amp;#10;                    if (((resp_agent1.keys === &quot;n&quot;) || (resp_agent1.keys === &quot;num_2&quot;))) {&amp;#10;                        this_agent1_move = &quot;down&quot;;&amp;#10;                        agent1_pos = [agent1_pos[0], (agent1_pos[1] - 0.15)];&amp;#10;                        agent1.image = agent1_imgs[&quot;down&quot;];&amp;#10;                        psychoJS.window.flip();&amp;#10;                    } else {&amp;#10;                        this_agent1_move = &quot;null&quot;;&amp;#10;                        agent1.image = agent1_imgs[&quot;down&quot;];&amp;#10;                        psychoJS.window.flip();&amp;#10;                    }&amp;#10;                }&amp;#10;            }&amp;#10;        }&amp;#10;        agent1.setPos(agent1_pos, {&quot;log&quot;: true});&amp;#10;        agent1_indicator_text.setPos(agent1_pos, {&quot;log&quot;: true});&amp;#10;        if ((agent1_pos[0] &gt; 0.3)) {&amp;#10;            egg_right.setAutoDraw(false);&amp;#10;        }&amp;#10;        if ((agent1_pos[0] &lt; (- 0.3))) {&amp;#10;            egg_left.setAutoDraw(false);&amp;#10;        }&amp;#10;        psychoJS.window.flip();&amp;#10;        continueRoutine = false;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
