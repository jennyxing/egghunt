        <Param val="agent2_jitter = np.random.uniform(1, 1.5);&amp;#10;psychoJS.experiment.addData(&quot;agent2_jitter&quot;, agent2_jitter);&amp;#10;instr_agent2.bold = true;&amp;#10;[out_x, out_y, possiblemoves] = convert_coords(agent2_pos[0], agent2_pos[1], {&quot;agent&quot;: &quot;player2&quot;});&amp;#10;for (var this_move, _pj_c = 0, _pj_a = possiblemoves, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    this_move = _pj_a[_pj_c];&amp;#10;    [x_shift, y_shift] = convert_moves(this_move);&amp;#10;    if (([(agent2_pos[0] + x_shift), (agent2_pos[1] + y_shift)] === chick1_pos)) {&amp;#10;        possiblemoves.remove(this_move);&amp;#10;    }&amp;#10;    if (([(agent2_pos[0] + x_shift), (agent2_pos[1] + y_shift)] === agent1_pos)) {&amp;#10;        possiblemoves.remove(this_move);&amp;#10;    }&amp;#10;}&amp;#10;this_agent2_move = &quot;&quot;;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="agent2_jitter = np.random.uniform(1,1.5)&amp;#10;thisExp.addData('agent2_jitter', agent2_jitter)&amp;#10;&amp;#10;instr_agent2.bold = True&amp;#10;&amp;#10;# get grid coords and moves&amp;#10;out_x, out_y, possiblemoves = convert_coords(agent2_pos[0], agent2_pos[1], agent='player2')&amp;#10;&amp;#10;# remove possible move if adjacent to another agent&amp;#10;for this_move in possiblemoves:&amp;#10;    x_shift, y_shift = convert_moves(this_move)&amp;#10;    if [agent2_pos[0]+x_shift, agent2_pos[1]+y_shift] == chick1_pos:&amp;#10;        possiblemoves.remove(this_move)&amp;#10;    if [agent2_pos[0]+x_shift, agent2_pos[1]+y_shift] == agent1_pos:&amp;#10;        possiblemoves.remove(this_move)&amp;#10;        &amp;#10;this_agent2_move = ''&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="#if resp_agent2.keys:&amp;#10;current_agent2_keyresp = resp_agent2.getKeys(clear=True)&amp;#10;if current_agent2_keyresp:&amp;#10;    if resp_agent2.keys in possiblemoves:&amp;#10;        if resp_agent2.keys == 'num_4':&amp;#10;            this_agent2_move = 'left'&amp;#10;            agent2_pos = [agent2_pos[0]-.15, agent2_pos[1]]&amp;#10;            agent2.image = agent2_imgs['left']&amp;#10;            &amp;#10;            # store timing:&amp;#10;            agent2_move_onset_time = globalClock.getTime() - trigger_time&amp;#10;            thisExp.addData('agent2_move_onset', agent2_move_onset_time)&amp;#10;&amp;#10;            agent2_move_since_round_start = globalClock.getTime() - round_start_time&amp;#10;            thisExp.addData('agent2_move_onset_from_round_start', agent2_move_since_round_start)&amp;#10;&amp;#10;            win.flip()&amp;#10;        elif resp_agent2.keys == 'num_6':&amp;#10;            this_agent2_move = 'right'&amp;#10;            agent2_pos = [agent2_pos[0]+.15, agent2_pos[1]]&amp;#10;            agent2.image = agent2_imgs['right']&amp;#10;            &amp;#10;            # store timing:&amp;#10;            agent2_move_onset_time = globalClock.getTime() - trigger_time&amp;#10;            thisExp.addData('agent2_move_onset', agent2_move_onset_time)&amp;#10;&amp;#10;            agent2_move_since_round_start = globalClock.getTime() - round_start_time&amp;#10;            thisExp.addData('agent2_move_onset_from_round_start', agent2_move_since_round_start)&amp;#10;&amp;#10;            win.flip()&amp;#10;        elif resp_agent2.keys == 'num_8':&amp;#10;            this_agent2_move = 'up'&amp;#10;            agent2_pos = [agent2_pos[0], agent2_pos[1]+.15]&amp;#10;            agent2.image = agent2_imgs['up']&amp;#10;            &amp;#10;            # store timing:&amp;#10;            agent2_move_onset_time = globalClock.getTime() - trigger_time&amp;#10;            thisExp.addData('agent2_move_onset', agent2_move_onset_time)&amp;#10;&amp;#10;            agent2_move_since_round_start = globalClock.getTime() - round_start_time&amp;#10;            thisExp.addData('agent2_move_onset_from_round_start', agent2_move_since_round_start)&amp;#10;&amp;#10;            win.flip()&amp;#10;        elif resp_agent2.keys == 'num_2':&amp;#10;            this_agent2_move = 'down'&amp;#10;            agent2_pos = [agent2_pos[0], agent2_pos[1]-.15]&amp;#10;            agent2.image = agent2_imgs['down']&amp;#10;            &amp;#10;            # store timing:&amp;#10;            agent2_move_onset_time = globalClock.getTime() - trigger_time&amp;#10;            thisExp.addData('agent2_move_onset', agent2_move_onset_time)&amp;#10;&amp;#10;            agent2_move_since_round_start = globalClock.getTime() - round_start_time&amp;#10;            thisExp.addData('agent2_move_onset_from_round_start', agent2_move_since_round_start)&amp;#10;&amp;#10;            win.flip()&amp;#10;        else:&amp;#10;            this_agent2_move = 'null'&amp;#10;            agent2.image = agent2_imgs['down']&amp;#10;            &amp;#10;            # store timing:&amp;#10;            agent2_move_onset_time = globalClock.getTime() - trigger_time&amp;#10;            thisExp.addData('agent2_move_onset', agent2_move_onset_time)&amp;#10;&amp;#10;            agent2_move_since_round_start = globalClock.getTime() - round_start_time&amp;#10;            thisExp.addData('agent2_move_onset_from_round_start', agent2_move_since_round_start)&amp;#10;&amp;#10;            win.flip()&amp;#10;            &amp;#10;        agent2.setPos(agent2_pos, log=True)&amp;#10;        agent2_indicator_text.setPos(agent2_pos, log=True)&amp;#10;        &amp;#10;        if agent2_pos[0] &gt; .3:&amp;#10;            egg_right.setAutoDraw(False)&amp;#10;        if agent2_pos[0] &lt; -.3:&amp;#10;            egg_left.setAutoDraw(False)&amp;#10;        win.flip()&amp;#10;        continueRoutine = False" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="var _pj;&amp;#10;function _pj_snippets(container) {&amp;#10;    function in_es6(left, right) {&amp;#10;        if (((right instanceof Array) || ((typeof right) === &quot;string&quot;))) {&amp;#10;            return (right.indexOf(left) &gt; (- 1));&amp;#10;        } else {&amp;#10;            if (((right instanceof Map) || (right instanceof Set) || (right instanceof WeakMap) || (right instanceof WeakSet))) {&amp;#10;                return right.has(left);&amp;#10;            } else {&amp;#10;                return (left in right);&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    container[&quot;in_es6&quot;] = in_es6;&amp;#10;    return container;&amp;#10;}&amp;#10;_pj = {};&amp;#10;_pj_snippets(_pj);&amp;#10;current_agent2_keyresp = resp_agent2.getKeys({&quot;clear&quot;: true});&amp;#10;if (current_agent2_keyresp) {&amp;#10;    if (_pj.in_es6(resp_agent2.keys, possiblemoves)) {&amp;#10;        if ((resp_agent2.keys === &quot;num_4&quot;)) {&amp;#10;            this_agent2_move = &quot;left&quot;;&amp;#10;            agent2_pos = [(agent2_pos[0] - 0.15), agent2_pos[1]];&amp;#10;            agent2.image = agent2_imgs[&quot;left&quot;];&amp;#10;            agent2_move_onset_time = (globalClock.getTime() - trigger_time);&amp;#10;            psychoJS.experiment.addData(&quot;agent2_move_onset&quot;, agent2_move_onset_time);&amp;#10;            agent2_move_since_round_start = (globalClock.getTime() - round_start_time);&amp;#10;            psychoJS.experiment.addData(&quot;agent2_move_onset_from_round_start&quot;, agent2_move_since_round_start);&amp;#10;            psychoJS.window.flip();&amp;#10;        } else {&amp;#10;            if ((resp_agent2.keys === &quot;num_6&quot;)) {&amp;#10;                this_agent2_move = &quot;right&quot;;&amp;#10;                agent2_pos = [(agent2_pos[0] + 0.15), agent2_pos[1]];&amp;#10;                agent2.image = agent2_imgs[&quot;right&quot;];&amp;#10;                agent2_move_onset_time = (globalClock.getTime() - trigger_time);&amp;#10;                psychoJS.experiment.addData(&quot;agent2_move_onset&quot;, agent2_move_onset_time);&amp;#10;                agent2_move_since_round_start = (globalClock.getTime() - round_start_time);&amp;#10;                psychoJS.experiment.addData(&quot;agent2_move_onset_from_round_start&quot;, agent2_move_since_round_start);&amp;#10;                psychoJS.window.flip();&amp;#10;            } else {&amp;#10;                if ((resp_agent2.keys === &quot;num_8&quot;)) {&amp;#10;                    this_agent2_move = &quot;up&quot;;&amp;#10;                    agent2_pos = [agent2_pos[0], (agent2_pos[1] + 0.15)];&amp;#10;                    agent2.image = agent2_imgs[&quot;up&quot;];&amp;#10;                    agent2_move_onset_time = (globalClock.getTime() - trigger_time);&amp;#10;                    psychoJS.experiment.addData(&quot;agent2_move_onset&quot;, agent2_move_onset_time);&amp;#10;                    agent2_move_since_round_start = (globalClock.getTime() - round_start_time);&amp;#10;                    psychoJS.experiment.addData(&quot;agent2_move_onset_from_round_start&quot;, agent2_move_since_round_start);&amp;#10;                    psychoJS.window.flip();&amp;#10;                } else {&amp;#10;                    if ((resp_agent2.keys === &quot;num_2&quot;)) {&amp;#10;                        this_agent2_move = &quot;down&quot;;&amp;#10;                        agent2_pos = [agent2_pos[0], (agent2_pos[1] - 0.15)];&amp;#10;                        agent2.image = agent2_imgs[&quot;down&quot;];&amp;#10;                        agent2_move_onset_time = (globalClock.getTime() - trigger_time);&amp;#10;                        psychoJS.experiment.addData(&quot;agent2_move_onset&quot;, agent2_move_onset_time);&amp;#10;                        agent2_move_since_round_start = (globalClock.getTime() - round_start_time);&amp;#10;                        psychoJS.experiment.addData(&quot;agent2_move_onset_from_round_start&quot;, agent2_move_since_round_start);&amp;#10;                        psychoJS.window.flip();&amp;#10;                    } else {&amp;#10;                        this_agent2_move = &quot;null&quot;;&amp;#10;                        agent2.image = agent2_imgs[&quot;down&quot;];&amp;#10;                        agent2_move_onset_time = (globalClock.getTime() - trigger_time);&amp;#10;                        psychoJS.experiment.addData(&quot;agent2_move_onset&quot;, agent2_move_onset_time);&amp;#10;                        agent2_move_since_round_start = (globalClock.getTime() - round_start_time);&amp;#10;                        psychoJS.experiment.addData(&quot;agent2_move_onset_from_round_start&quot;, agent2_move_since_round_start);&amp;#10;                        psychoJS.window.flip();&amp;#10;                    }&amp;#10;                }&amp;#10;            }&amp;#10;        }&amp;#10;        agent2.setPos(agent2_pos, {&quot;log&quot;: true});&amp;#10;        agent2_indicator_text.setPos(agent2_pos, {&quot;log&quot;: true});&amp;#10;        if ((agent2_pos[0] &gt; 0.3)) {&amp;#10;            egg_right.setAutoDraw(false);&amp;#10;        }&amp;#10;        if ((agent2_pos[0] &lt; (- 0.3))) {&amp;#10;            egg_left.setAutoDraw(false);&amp;#10;        }&amp;#10;        psychoJS.window.flip();&amp;#10;        continueRoutine = false;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="var _pj;&amp;#10;function _pj_snippets(container) {&amp;#10;    function in_es6(left, right) {&amp;#10;        if (((right instanceof Array) || ((typeof right) === &quot;string&quot;))) {&amp;#10;            return (right.indexOf(left) &gt; (- 1));&amp;#10;        } else {&amp;#10;            if (((right instanceof Map) || (right instanceof Set) || (right instanceof WeakMap) || (right instanceof WeakSet))) {&amp;#10;                return right.has(left);&amp;#10;            } else {&amp;#10;                return (left in right);&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    container[&quot;in_es6&quot;] = in_es6;&amp;#10;    return container;&amp;#10;}&amp;#10;_pj = {};&amp;#10;_pj_snippets(_pj);&amp;#10;if (_pj.in_es6(this_agent2_move, [&quot;up&quot;, &quot;down&quot;, &quot;left&quot;, &quot;right&quot;])) {&amp;#10;    psychoJS.experiment.addData(`agent2_action`, this_agent2_move);&amp;#10;} else {&amp;#10;    psychoJS.experiment.addData(`agent2_action`, &quot;null&quot;);&amp;#10;}&amp;#10;core.wait(agent2_jitter);&amp;#10;agent2.image = agent2_imgs[&quot;down&quot;];&amp;#10;psychoJS.window.flip();&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="#print('agent2', out_x, out_y, possiblemoves, resp_agent2.keys, agent2_pos)&amp;#10;&amp;#10;if this_agent2_move in ['up','down','left','right']:&amp;#10;    thisExp.addData(f'agent2_action', this_agent2_move)&amp;#10;else:&amp;#10;    thisExp.addData(f'agent2_action', 'null')&amp;#10;&amp;#10;core.wait(agent2_jitter)&amp;#10;agent2.image = agent2_imgs['down']&amp;#10;win.flip()" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="change_agent2" valType="code" updates="None" name="name"/>
      </CodeComponent>
    </Routine>
    <Routine name="move_chick2">
      <CodeComponent name="change_chick_2">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if ((Number.parseInt(expInfo[&quot;nchicks&quot;]) &gt;= 2)) {&amp;#10;    [out_x, out_y, possiblemoves] = convert_coords(chick2_pos[0], chick2_pos[1]);&amp;#10;    flag = true;&amp;#10;    while (flag) {&amp;#10;        this_stag_move = np.random.choice(possiblemoves);&amp;#10;        [x_shift, y_shift] = convert_moves(this_stag_move);&amp;#10;        if (((([(chick2_pos[0] + x_shift), (chick2_pos[1] + y_shift)] === agent2_pos) || ([(chick2_pos[0] + x_shift), (chick2_pos[1] + y_shift)] === chick1_pos)) || ([(chick2_pos[0] + x_shift), (chick2_pos[1] + y_shift)] === agent1_pos))) {&amp;#10;            flag = true;&amp;#10;            possiblemoves.remove(this_stag_move);&amp;#10;        } else {&amp;#10;            if ((Math.abs((chick2_pos[0] + x_shift)) &gt; 0.35)) {&amp;#10;                flag = true;&amp;#10;                possiblemoves.remove(this_stag_move);&amp;#10;            } else {&amp;#10;                flag = false;&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    if ((this_stag_move === &quot;right&quot;)) {&amp;#10;        chick2.flipHoriz = true;&amp;#10;    }&amp;#10;    if ((this_stag_move === &quot;left&quot;)) {&amp;#10;        chick2.flipHoriz = false;&amp;#10;    }&amp;#10;} else {&amp;#10;    console.log(&quot;no chick 2&quot;);&amp;#10;    continueRoutine = false;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="if int(expInfo['nchicks']) &gt;= 2:&amp;#10;    # get grid coords and moves&amp;#10;    out_x, out_y, possiblemoves = convert_coords(chick2_pos[0], chick2_pos[1])&amp;#10;&amp;#10;    flag = True&amp;#10;    while flag:&amp;#10;        this_stag_move = np.random.choice(possiblemoves)&amp;#10;        x_shift, y_shift = convert_moves(this_stag_move)&amp;#10;&amp;#10;        if ([chick2_pos[0]+x_shift, chick2_pos[1]+y_shift] == agent2_pos) or ([chick2_pos[0]+x_shift, chick2_pos[1]+y_shift] == chick1_pos) or ([chick2_pos[0]+x_shift, chick2_pos[1]+y_shift] == agent1_pos):&amp;#10;            flag = True&amp;#10;            possiblemoves.remove(this_stag_move)&amp;#10;        elif (abs(chick2_pos[0]+x_shift) &gt; .35):&amp;#10;            flag = True&amp;#10;            possiblemoves.remove(this_stag_move)&amp;#10;        else:&amp;#10;            flag = False&amp;#10;&amp;#10;    if this_stag_move == 'right':&amp;#10;        chick2.flipHoriz = True&amp;#10;&amp;#10;    if this_stag_move == 'left':&amp;#10;        chick2.flipHoriz = False&amp;#10;else:&amp;#10;    print('no chick 2')&amp;#10;    continueRoutine = False&amp;#10;    &amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="if int(expInfo['nchicks']) == 1:&amp;#10;    continueRoutine = False" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="if ((Number.parseInt(expInfo[&quot;nchicks&quot;]) === 1)) {&amp;#10;    continueRoutine = false;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="if ((Number.parseInt(expInfo[&quot;nchicks&quot;]) &gt;= 2)) {&amp;#10;    chick2_pos = [(chick2_pos[0] + x_shift), (chick2_pos[1] + y_shift)];&amp;#10;    chick2.setPos(chick2_pos, {&quot;log&quot;: true});&amp;#10;    console.log(&quot;chick2&quot;, out_x, out_y, possiblemoves, this_stag_move);&amp;#10;    psychoJS.window.flip();&amp;#10;    core.wait(1);&amp;#10;} else {&amp;#10;    continueRoutine = false;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="if int(expInfo['nchicks']) &gt;= 2:&amp;#10;    chick2_pos = [chick2_pos[0]+x_shift, chick2_pos[1]+y_shift]&amp;#10;    chick2.setPos(chick2_pos, log=True)&amp;#10;    print('chick2', out_x, out_y, possiblemoves, this_stag_move)&amp;#10;&amp;#10;    win.flip()&amp;#10;    core.wait(1)&amp;#10;else:&amp;#10;    continueRoutine = False" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="change_chick_2" valType="code" updates="None" name="name"/>
      </CodeComponent>
