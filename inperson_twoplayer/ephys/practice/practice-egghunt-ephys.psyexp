        <Param val="agent1_jitter = np.random.uniform(1, 1.5);&amp;#10;psychoJS.experiment.addData(&quot;agent1_jitter&quot;, agent1_jitter);&amp;#10;instr_agent1_3.bold = true;&amp;#10;agent1_indicator_text.color = &quot;red&quot;;&amp;#10;possiblemoves = [left_key];&amp;#10;this_instr_txt = `Your turn. Both of you can collect an egg this time.&amp;#10;Press the ${left_key.replace(&quot;num_&quot;, &quot;&quot;)} key to move left to collect the egg`&amp;#10;;&amp;#10;this_agent1_move = &quot;&quot;;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="agent1_jitter = np.random.uniform(1,1.5)&amp;#10;thisExp.addData('agent1_jitter', agent1_jitter)&amp;#10;&amp;#10;instr_agent1_3.bold = True&amp;#10;agent1_indicator_text.color = &quot;red&quot;&amp;#10;&amp;#10;# remove possible move if adjacent to another agent&amp;#10;possiblemoves = [left_key]&amp;#10;this_instr_txt = f'Your turn. Both of you can collect an egg this time.\nPress the {left_key.replace(&quot;num_&quot;,&quot;&quot;)} key to move left to collect the egg'&amp;#10;&amp;#10;this_agent1_move = ''" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="current_agent1_keyresp = resp_agent1_3.getKeys(clear=True)&amp;#10;if resp_agent1_3.keys == 'escape':&amp;#10;    core.quit()&amp;#10;if current_agent1_keyresp:&amp;#10;     if resp_agent1_3.keys in possiblemoves:&amp;#10;        if resp_agent1_3.keys == 'h' or resp_agent1_3.keys == 'num_4':&amp;#10;            this_agent1_move = 'left'&amp;#10;            agent1_pos = [agent1_pos[0]-.15, agent1_pos[1]]&amp;#10;            agent1.image = agent1_imgs['left']&amp;#10;            &amp;#10;            win.flip()&amp;#10;        elif resp_agent1_3.keys == 'k' or resp_agent1_3.keys == 'num_6':&amp;#10;            this_agent1_move = 'right'&amp;#10;            agent1_pos = [agent1_pos[0]+.15, agent1_pos[1]]&amp;#10;            agent1.image = agent1_imgs['right']&amp;#10;            &amp;#10;            win.flip()&amp;#10;        elif resp_agent1_3.keys == 'u' or resp_agent1_3.keys == 'num_8':&amp;#10;            this_agent1_move = 'up'&amp;#10;            agent1_pos = [agent1_pos[0], agent1_pos[1]+.15]&amp;#10;            agent1.image = agent1_imgs['up']&amp;#10;            &amp;#10;            win.flip()&amp;#10;        elif resp_agent1_3.keys == 'n' or resp_agent1_3.keys == 'num_2':&amp;#10;            this_agent1_move = 'down'&amp;#10;            agent1_pos = [agent1_pos[0], agent1_pos[1]-.15]&amp;#10;            agent1.image = agent1_imgs['down']&amp;#10;            &amp;#10;            win.flip()&amp;#10;        else:&amp;#10;            this_agent1_move = 'null'&amp;#10;            agent1.image = agent1_imgs['down']&amp;#10;            &amp;#10;            win.flip()&amp;#10;            &amp;#10;        agent1.setPos(agent1_pos, log=True)&amp;#10;        agent1_indicator_text.setPos(agent1_pos, log=True)&amp;#10;        &amp;#10;        if agent1_pos[0] &gt; .3:&amp;#10;            egg_right.setAutoDraw(False)&amp;#10;        if agent1_pos[0] &lt; -.3:&amp;#10;            egg_left.setAutoDraw(False)&amp;#10;        win.flip()&amp;#10;        continueRoutine = False" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="var _pj;&amp;#10;function _pj_snippets(container) {&amp;#10;    function in_es6(left, right) {&amp;#10;        if (((right instanceof Array) || ((typeof right) === &quot;string&quot;))) {&amp;#10;            return (right.indexOf(left) &gt; (- 1));&amp;#10;        } else {&amp;#10;            if (((right instanceof Map) || (right instanceof Set) || (right instanceof WeakMap) || (right instanceof WeakSet))) {&amp;#10;                return right.has(left);&amp;#10;            } else {&amp;#10;                return (left in right);&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    container[&quot;in_es6&quot;] = in_es6;&amp;#10;    return container;&amp;#10;}&amp;#10;_pj = {};&amp;#10;_pj_snippets(_pj);&amp;#10;current_agent1_keyresp = resp_agent1_3.getKeys({&quot;clear&quot;: true});&amp;#10;if ((resp_agent1_3.keys === &quot;escape&quot;)) {&amp;#10;    core.quit();&amp;#10;}&amp;#10;if (current_agent1_keyresp) {&amp;#10;    if (_pj.in_es6(resp_agent1_3.keys, possiblemoves)) {&amp;#10;        if (((resp_agent1_3.keys === &quot;h&quot;) || (resp_agent1_3.keys === &quot;num_4&quot;))) {&amp;#10;            this_agent1_move = &quot;left&quot;;&amp;#10;            agent1_pos = [(agent1_pos[0] - 0.15), agent1_pos[1]];&amp;#10;            agent1.image = agent1_imgs[&quot;left&quot;];&amp;#10;            psychoJS.window.flip();&amp;#10;        } else {&amp;#10;            if (((resp_agent1_3.keys === &quot;k&quot;) || (resp_agent1_3.keys === &quot;num_6&quot;))) {&amp;#10;                this_agent1_move = &quot;right&quot;;&amp;#10;                agent1_pos = [(agent1_pos[0] + 0.15), agent1_pos[1]];&amp;#10;                agent1.image = agent1_imgs[&quot;right&quot;];&amp;#10;                psychoJS.window.flip();&amp;#10;            } else {&amp;#10;                if (((resp_agent1_3.keys === &quot;u&quot;) || (resp_agent1_3.keys === &quot;num_8&quot;))) {&amp;#10;                    this_agent1_move = &quot;up&quot;;&amp;#10;                    agent1_pos = [agent1_pos[0], (agent1_pos[1] + 0.15)];&amp;#10;                    agent1.image = agent1_imgs[&quot;up&quot;];&amp;#10;                    psychoJS.window.flip();&amp;#10;                } else {&amp;#10;                    if (((resp_agent1_3.keys === &quot;n&quot;) || (resp_agent1_3.keys === &quot;num_2&quot;))) {&amp;#10;                        this_agent1_move = &quot;down&quot;;&amp;#10;                        agent1_pos = [agent1_pos[0], (agent1_pos[1] - 0.15)];&amp;#10;                        agent1.image = agent1_imgs[&quot;down&quot;];&amp;#10;                        psychoJS.window.flip();&amp;#10;                    } else {&amp;#10;                        this_agent1_move = &quot;null&quot;;&amp;#10;                        agent1.image = agent1_imgs[&quot;down&quot;];&amp;#10;                        psychoJS.window.flip();&amp;#10;                    }&amp;#10;                }&amp;#10;            }&amp;#10;        }&amp;#10;        agent1.setPos(agent1_pos, {&quot;log&quot;: true});&amp;#10;        agent1_indicator_text.setPos(agent1_pos, {&quot;log&quot;: true});&amp;#10;        if ((agent1_pos[0] &gt; 0.3)) {&amp;#10;            egg_right.setAutoDraw(false);&amp;#10;        }&amp;#10;        if ((agent1_pos[0] &lt; (- 0.3))) {&amp;#10;            egg_left.setAutoDraw(false);&amp;#10;        }&amp;#10;        psychoJS.window.flip();&amp;#10;        continueRoutine = false;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="var _pj;&amp;#10;function _pj_snippets(container) {&amp;#10;    function in_es6(left, right) {&amp;#10;        if (((right instanceof Array) || ((typeof right) === &quot;string&quot;))) {&amp;#10;            return (right.indexOf(left) &gt; (- 1));&amp;#10;        } else {&amp;#10;            if (((right instanceof Map) || (right instanceof Set) || (right instanceof WeakMap) || (right instanceof WeakSet))) {&amp;#10;                return right.has(left);&amp;#10;            } else {&amp;#10;                return (left in right);&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    container[&quot;in_es6&quot;] = in_es6;&amp;#10;    return container;&amp;#10;}&amp;#10;_pj = {};&amp;#10;_pj_snippets(_pj);&amp;#10;if (_pj.in_es6(this_agent1_move, [&quot;up&quot;, &quot;down&quot;, &quot;left&quot;, &quot;right&quot;])) {&amp;#10;    psychoJS.experiment.addData(`agent1_action`, this_agent1_move);&amp;#10;} else {&amp;#10;    psychoJS.experiment.addData(`agent1_action`, &quot;null&quot;);&amp;#10;}&amp;#10;core.wait(agent1_jitter);&amp;#10;agent1.image = agent1_imgs[&quot;down&quot;];&amp;#10;psychoJS.window.flip();&amp;#10;agent1_indicator_text.color = &quot;black&quot;;&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="if this_agent1_move in ['up','down','left','right']:&amp;#10;    thisExp.addData(f'agent1_action', this_agent1_move)&amp;#10;else:&amp;#10;    thisExp.addData(f'agent1_action', 'null')&amp;#10;&amp;#10;core.wait(agent1_jitter)&amp;#10;agent1.image = agent1_imgs['down']&amp;#10;win.flip()&amp;#10;&amp;#10;agent1_indicator_text.color = &quot;black&quot;" valType="extendedCode" updates="constant" name="End Routine"/>
