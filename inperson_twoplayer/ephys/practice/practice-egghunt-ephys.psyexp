        <Param val="count1_chick = 0;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="instr_chick.bold = true;&amp;#10;chick_jitter = np.random.uniform(2, 3);&amp;#10;chick_timer = new core.Clock();&amp;#10;count1_chick += 1;&amp;#10;if ((count1_chick === 1)) {&amp;#10;    x_shift = 0;&amp;#10;    y_shift = (- 0.15);&amp;#10;    this_chick_move_4 = &quot;down&quot;;&amp;#10;    this_chick_instr_txt = &quot;The chicken moves first&quot;;&amp;#10;} else {&amp;#10;    if ((count1_chick === 2)) {&amp;#10;        x_shift = 0;&amp;#10;        y_shift = (- 0.15);&amp;#10;        this_chick_move_4 = &quot;down&quot;;&amp;#10;        this_chick_instr_txt = &quot;It is the chicken's turn now&quot;;&amp;#10;    } else {&amp;#10;        if ((count1_chick === 3)) {&amp;#10;            x_shift = 0;&amp;#10;            y_shift = 0;&amp;#10;            this_chick_move_4 = &quot;stay&quot;;&amp;#10;            this_chick_instr_txt = &quot;It is the chicken's turn now&quot;;&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="instr_chick.bold = True&amp;#10;chick_jitter = np.random.uniform(2,3)&amp;#10;chick_timer = core.Clock()&amp;#10;&amp;#10;count1_chick += 1&amp;#10;if count1_chick == 1:&amp;#10;    # down&amp;#10;    x_shift = 0&amp;#10;    y_shift = -.15&amp;#10;    this_chick_move_4 = 'down'&amp;#10;    this_chick_instr_txt = 'The chicken moves first'&amp;#10;elif count1_chick == 2:&amp;#10;    # down&amp;#10;    x_shift = 0&amp;#10;    y_shift = -.15&amp;#10;    this_chick_move_4 = 'down'&amp;#10;    this_chick_instr_txt = 'It is the chicken\'s turn now'&amp;#10;elif count1_chick == 3:&amp;#10;    # down&amp;#10;    x_shift = 0&amp;#10;    y_shift = 0&amp;#10;    this_chick_move_4 = 'stay'&amp;#10;    this_chick_instr_txt = 'It is the chicken\'s turn now'&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="if chick_timer.getTime()&gt;chick_jitter:&amp;#10;    &amp;#10;    chick1.image = chick1_imgs[this_chick_move_4]&amp;#10;    chick1_pos = [chick1_pos[0]+x_shift, chick1_pos[1]+y_shift]&amp;#10;    chick1.setPos(chick1_pos, log=True)&amp;#10;&amp;#10;    win.flip()&amp;#10;    core.wait(1)&amp;#10;&amp;#10;    chick1.image = chick1_imgs['down']&amp;#10;    win.flip()&amp;#10;    continueRoutine = False" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="if ((chick_timer.getTime() &gt; chick_jitter)) {&amp;#10;    chick1.image = chick1_imgs[this_chick_move_4];&amp;#10;    chick1_pos = [(chick1_pos[0] + x_shift), (chick1_pos[1] + y_shift)];&amp;#10;    chick1.setPos(chick1_pos, {&quot;log&quot;: true});&amp;#10;    psychoJS.window.flip();&amp;#10;    core.wait(1);&amp;#10;    chick1.image = chick1_imgs[&quot;down&quot;];&amp;#10;    psychoJS.window.flip();&amp;#10;    continueRoutine = false;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
