        <Param val="if expInfo['player'] == '1':&amp;#10;    agent1_pts = 100+(150-30)&amp;#10;    agent2_pts = 150-30&amp;#10;elif expInfo['player'] == '2':&amp;#10;    agent1_pts = 150-30&amp;#10;    agent2_pts = 100+(150-30)&amp;#10;        &amp;#10;        &amp;#10;agent1_complete_text = f'PLAYER 1:\n+{agent1_pts} points\n\n'&amp;#10;agent2_complete_text = f'PLAYER 2:\n+{agent2_pts} points'&amp;#10;&amp;#10;round_complete_text = f'ROUND COMPLETED\n\n' + agent1_complete_text + agent2_complete_text&amp;#10;" valType="extendedCode" updates="constant" name="Begin Experiment"/>
