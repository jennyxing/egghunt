        <Param val="instr_computer_2.bold = true;&amp;#10;agent2_indicator_text.color = &quot;red&quot;;&amp;#10;timer2 = new core.Clock();&amp;#10;count2_comp += 1;&amp;#10;if ((count2_comp === 1)) {&amp;#10;    x_shift = (- 0.15);&amp;#10;    y_shift = 0;&amp;#10;    this_comp_move_2 = &quot;left&quot;;&amp;#10;    this_comp_instr_txt = &quot;It is the other player's turn now&quot;;&amp;#10;} else {&amp;#10;    if ((count2_comp === 2)) {&amp;#10;        x_shift = (- 0.15);&amp;#10;        y_shift = 0;&amp;#10;        this_comp_move_2 = &quot;left&quot;;&amp;#10;        this_comp_instr_txt = &quot;It is the other player's turn now&quot;;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
