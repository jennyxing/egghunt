        <Param val="&amp;#10;if expInfo['player'] == '1':&amp;#10;    agent1_pts2 = (150-20)&amp;#10;    agent2_pts2 = 100+(150-20)&amp;#10;elif expInfo['player'] == '2':&amp;#10;    agent1_pts2 = 100+(150-20)&amp;#10;    agent2_pts2 = (150-20)&amp;#10;agent1_complete_text2 = f'PLAYER 1:\n+{agent1_pts2} points\n\n'&amp;#10;agent2_complete_text2 = f'PLAYER 2:\n+{agent2_pts2} points'&amp;#10;round_complete_text2 = f'ROUND COMPLETED\n\n' + agent1_complete_text2 + agent2_complete_text2&amp;#10;" valType="extendedCode" updates="constant" name="Begin Experiment"/>
