        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="p1_avatar_selection = p1_mouse.clicked_name[0];&amp;#10;console.log(p1_avatar_selection);&amp;#10;text_reveal_2 = new visual.TextStim({&quot;win&quot;: psychoJS.window, &quot;name&quot;: &quot;text_reveal_2&quot;, &quot;text&quot;: &quot;PLAYER 2\nPlease use your mouse to choose your avatar.&quot;, &quot;font&quot;: &quot;Open Sans&quot;, &quot;pos&quot;: [0, 0.25], &quot;height&quot;: 0.045, &quot;wrapWidth&quot;: null, &quot;ori&quot;: 0.0, &quot;color&quot;: &quot;white&quot;, &quot;colorSpace&quot;: &quot;rgb&quot;, &quot;opacity&quot;: null, &quot;languageStyle&quot;: &quot;LTR&quot;, &quot;depth&quot;: (- 1.0)});&amp;#10;text_reveal_2.setAutoDraw(true);&amp;#10;choose_blue_2 = new visual.ImageStim({&quot;win&quot;: psychoJS.window, &quot;name&quot;: &quot;choose_blue_2&quot;, &quot;image&quot;: &quot;stimuli/player-blue.png&quot;, &quot;mask&quot;: null, &quot;anchor&quot;: &quot;center&quot;, &quot;ori&quot;: 0.0, &quot;pos&quot;: [random_avatar_pos[0]], &quot;size&quot;: [0.15, 0.15], &quot;color&quot;: [1, 1, 1], &quot;colorSpace&quot;: &quot;rgb&quot;, &quot;opacity&quot;: null, &quot;flipHoriz&quot;: false, &quot;flipVert&quot;: false, &quot;texRes&quot;: 128.0, &quot;interpolate&quot;: true, &quot;depth&quot;: (- 2.0)});&amp;#10;choose_blue_2.setAutoDraw(true);&amp;#10;choose_pink_2 = new visual.ImageStim({&quot;win&quot;: psychoJS.window, &quot;name&quot;: &quot;choose_pink_2&quot;, &quot;image&quot;: &quot;stimuli/player-pink.png&quot;, &quot;mask&quot;: null, &quot;anchor&quot;: &quot;center&quot;, &quot;ori&quot;: 0.0, &quot;pos&quot;: [random_avatar_pos[1]], &quot;size&quot;: [0.15, 0.15], &quot;color&quot;: [1, 1, 1], &quot;colorSpace&quot;: &quot;rgb&quot;, &quot;opacity&quot;: null, &quot;flipHoriz&quot;: false, &quot;flipVert&quot;: false, &quot;texRes&quot;: 128.0, &quot;interpolate&quot;: true, &quot;depth&quot;: (- 3.0)});&amp;#10;choose_pink_2.setAutoDraw(true);&amp;#10;choose_yellow_2 = new visual.ImageStim({&quot;win&quot;: psychoJS.window, &quot;name&quot;: &quot;choose_yellow_2&quot;, &quot;image&quot;: &quot;stimuli/player-yellow.png&quot;, &quot;mask&quot;: null, &quot;anchor&quot;: &quot;center&quot;, &quot;ori&quot;: 0.0, &quot;pos&quot;: [random_avatar_pos[2]], &quot;size&quot;: [0.15, 0.15], &quot;color&quot;: [1, 1, 1], &quot;colorSpace&quot;: &quot;rgb&quot;, &quot;opacity&quot;: null, &quot;flipHoriz&quot;: false, &quot;flipVert&quot;: false, &quot;texRes&quot;: 128.0, &quot;interpolate&quot;: true, &quot;depth&quot;: (- 4.0)});&amp;#10;choose_yellow_2.setAutoDraw(true);&amp;#10;if ((p1_avatar_selection === &quot;choose_pink&quot;)) {&amp;#10;    choose_pink_2.setOpacity(0.5);&amp;#10;    agent1_img = &quot;stimuli/player-pink.png&quot;;&amp;#10;    avail_stim = [&quot;stimuli/player-blue.png&quot;, &quot;stimuli/player-yellow.png&quot;];&amp;#10;    p2_clickable_stimuli = [choose_yellow_2, choose_blue_2];&amp;#10;} else {&amp;#10;    if ((p1_avatar_selection === &quot;choose_yellow&quot;)) {&amp;#10;        choose_yellow_2.setOpacity(0.5);&amp;#10;        agent1_img = &quot;stimuli/player-yellow.png&quot;;&amp;#10;        avail_stim = [&quot;stimuli/player-blue.png&quot;, &quot;stimuli/player-pink.png&quot;];&amp;#10;        p2_clickable_stimuli = [choose_pink_2, choose_blue_2];&amp;#10;    } else {&amp;#10;        if ((p1_avatar_selection === &quot;choose_blue&quot;)) {&amp;#10;            choose_blue_2.setOpacity(0.5);&amp;#10;            agent1_img = &quot;stimuli/player-blue.png&quot;;&amp;#10;            avail_stim = [&quot;stimuli/player-pink.png&quot;, &quot;stimuli/player-yellow.png&quot;];&amp;#10;            p2_clickable_stimuli = [choose_pink_2, choose_yellow_2];&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;psychoJS.window.flip();&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="#win.mouseVisible = False&amp;#10;&amp;#10;p1_avatar_selection = p1_mouse.clicked_name[0]&amp;#10;print(p1_avatar_selection)&amp;#10;&amp;#10;text_reveal_2 = visual.TextStim(win=win, name='text_reveal_2',&amp;#10;    text='PLAYER 2\nPlease use your mouse to choose your avatar.',&amp;#10;    font='Open Sans',&amp;#10;    pos=(0, .25), height=0.045, wrapWidth=None, ori=0.0, &amp;#10;    color='white', colorSpace='rgb', opacity=None, &amp;#10;    languageStyle='LTR',&amp;#10;    depth=-1.0);&amp;#10;text_reveal_2.setAutoDraw(True)&amp;#10;&amp;#10;choose_blue_2 = visual.ImageStim(&amp;#10;    win=win,&amp;#10;    name='choose_blue_2', &amp;#10;    image='stimuli/player-blue.png', mask=None, anchor='center',&amp;#10;    ori=0.0, pos=[random_avatar_pos[0]], size=(0.15, 0.15),&amp;#10;    color=[1,1,1], colorSpace='rgb', opacity=None,&amp;#10;    flipHoriz=False, flipVert=False,&amp;#10;    texRes=128.0, interpolate=True, depth=-2.0)&amp;#10;choose_blue_2.setAutoDraw(True)&amp;#10;&amp;#10;choose_pink_2 = visual.ImageStim(&amp;#10;    win=win,&amp;#10;    name='choose_pink_2', &amp;#10;    image='stimuli/player-pink.png', mask=None, anchor='center',&amp;#10;    ori=0.0, pos=[random_avatar_pos[1]], size=(0.15, 0.15),&amp;#10;    color=[1,1,1], colorSpace='rgb', opacity=None,&amp;#10;    flipHoriz=False, flipVert=False,&amp;#10;    texRes=128.0, interpolate=True, depth=-3.0)&amp;#10;choose_pink_2.setAutoDraw(True)&amp;#10;&amp;#10;choose_yellow_2 = visual.ImageStim(&amp;#10;    win=win,&amp;#10;    name='choose_yellow_2', &amp;#10;    image='stimuli/player-yellow.png', mask=None, anchor='center',&amp;#10;    ori=0.0, pos=[random_avatar_pos[2]], size=(0.15, 0.15),&amp;#10;    color=[1,1,1], colorSpace='rgb', opacity=None,&amp;#10;    flipHoriz=False, flipVert=False,&amp;#10;    texRes=128.0, interpolate=True, depth=-4.0)&amp;#10;choose_yellow_2.setAutoDraw(True)&amp;#10;&amp;#10;if p1_avatar_selection == 'choose_pink':&amp;#10;    choose_pink_2.setOpacity(.5)&amp;#10;    agent1_img = 'stimuli/player-pink.png'&amp;#10;    avail_stim = ['stimuli/player-blue.png','stimuli/player-yellow.png']&amp;#10;    p2_clickable_stimuli = [choose_yellow_2, choose_blue_2]&amp;#10;elif p1_avatar_selection == 'choose_yellow':&amp;#10;    choose_yellow_2.setOpacity(.5)&amp;#10;    agent1_img = 'stimuli/player-yellow.png'&amp;#10;    avail_stim = ['stimuli/player-blue.png','stimuli/player-pink.png']&amp;#10;    p2_clickable_stimuli = [choose_pink_2, choose_blue_2]&amp;#10;elif p1_avatar_selection == 'choose_blue':&amp;#10;    choose_blue_2.setOpacity(.5)&amp;#10;    agent1_img = 'stimuli/player-blue.png'&amp;#10;    avail_stim = ['stimuli/player-pink.png','stimuli/player-yellow.png']&amp;#10;    p2_clickable_stimuli = [choose_pink_2, choose_yellow_2]&amp;#10;&amp;#10;win.flip()&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="if ((p2_mouse.clicked_name[0] === &quot;choose_pink_2&quot;)) {&amp;#10;    choose_pink_2.setOpacity(0.5);&amp;#10;    agent2_img = &quot;stimuli/player-pink.png&quot;;&amp;#10;} else {&amp;#10;    if ((p2_mouse.clicked_name[0] === &quot;choose_yellow_2&quot;)) {&amp;#10;        choose_yellow_2.setOpacity(0.5);&amp;#10;        agent2_img = &quot;stimuli/player-yellow.png&quot;;&amp;#10;    } else {&amp;#10;        if ((p2_mouse.clicked_name[0] === &quot;choose_blue_2&quot;)) {&amp;#10;            choose_blue_2.setOpacity(0.5);&amp;#10;            agent2_img = &quot;stimuli/player-blue.png&quot;;&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;psychoJS.window.flip();&amp;#10;core.wait(1);&amp;#10;choose_blue_2.setAutoDraw(false);&amp;#10;choose_pink_2.setAutoDraw(false);&amp;#10;choose_yellow_2.setAutoDraw(false);&amp;#10;text_reveal_2.setAutoDraw(false);&amp;#10;agent1 = new visual.ImageStim({&quot;win&quot;: psychoJS.window, &quot;name&quot;: &quot;agent1&quot;, &quot;image&quot;: agent1_img, &quot;mask&quot;: null, &quot;anchor&quot;: &quot;center&quot;, &quot;ori&quot;: 0.0, &quot;pos&quot;: agent1_pos, &quot;size&quot;: [0.1, 0.1], &quot;color&quot;: [1, 1, 1], &quot;colorSpace&quot;: &quot;rgb&quot;, &quot;opacity&quot;: null, &quot;flipHoriz&quot;: false, &quot;flipVert&quot;: false, &quot;texRes&quot;: 128.0, &quot;interpolate&quot;: false, &quot;depth&quot;: (- 10.0)});&amp;#10;agent2 = new visual.ImageStim({&quot;win&quot;: psychoJS.window, &quot;name&quot;: &quot;agent2&quot;, &quot;image&quot;: agent2_img, &quot;mask&quot;: null, &quot;anchor&quot;: &quot;center&quot;, &quot;ori&quot;: 0.0, &quot;pos&quot;: agent2_pos, &quot;size&quot;: [0.1, 0.1], &quot;color&quot;: [1, 1, 1], &quot;colorSpace&quot;: &quot;rgb&quot;, &quot;opacity&quot;: null, &quot;flipHoriz&quot;: false, &quot;flipVert&quot;: false, &quot;texRes&quot;: 128.0, &quot;interpolate&quot;: false, &quot;depth&quot;: (- 10.0)});&amp;#10;GridWorldComponents = [b_0_2, b_0_1, b_3_0, b_2_2, b_1_2, b_2_1, b_2_neg1, b_2_neg2, b_2_0, b_1_neg2, b_1_0, b_0_0, b_neg1_0, b_neg1_2, b_neg1_neg2, b_neg2_0, b_neg2_1, b_neg2_neg1, b_neg2_neg2, b_neg2_2, b_neg3_0, b_0_neg1, b_0_neg2, rabbit_left, rabbit_right];&amp;#10;for (var thisComponent, _pj_c = 0, _pj_a = GridWorldComponents, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    thisComponent = _pj_a[_pj_c];&amp;#10;    if ((&quot;setAutoDraw&quot; in thisComponent)) {&amp;#10;        thisComponent.setAutoDraw(true);&amp;#10;    }&amp;#10;}&amp;#10;AgentsComponents = [agent1, agent2, chick1];&amp;#10;if ((nchicks &gt;= 2)) {&amp;#10;    AgentsComponents += [chick2];&amp;#10;}&amp;#10;if ((nchicks &gt;= 3)) {&amp;#10;    AgentsComponents += [chick3];&amp;#10;}&amp;#10;for (var thisComponent, _pj_c = 0, _pj_a = AgentsComponents, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    thisComponent = _pj_a[_pj_c];&amp;#10;    if ((&quot;setAutoDraw&quot; in thisComponent)) {&amp;#10;        thisComponent.setAutoDraw(true);&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
