        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="instr_computer.bold = true;&amp;#10;[out_x, out_y, possiblemoves] = convert_coords(agent2_pos[0], agent2_pos[1], {&quot;agent&quot;: &quot;computer&quot;});&amp;#10;flag = true;&amp;#10;while (flag) {&amp;#10;    this_agent2_move = np.random.choice(possiblemoves);&amp;#10;    [x_shift, y_shift] = convert_moves(this_agent2_move);&amp;#10;    if (([(agent2_pos[0] + x_shift), (agent2_pos[1] + y_shift)] === chick1_pos)) {&amp;#10;        flag = true;&amp;#10;        possiblemoves.remove(this_agent2_move);&amp;#10;    } else {&amp;#10;        if (([(agent2_pos[0] + x_shift), (agent2_pos[1] + y_shift)] === agent1_pos)) {&amp;#10;            flag = true;&amp;#10;            possiblemoves.remove(this_agent2_move);&amp;#10;        } else {&amp;#10;            flag = false;&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;if ((this_agent2_move === &quot;right&quot;)) {&amp;#10;    agent2.flipHoriz = true;&amp;#10;}&amp;#10;if ((this_agent2_move === &quot;left&quot;)) {&amp;#10;    agent2.flipHoriz = false;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="instr_computer.bold = True&amp;#10;&amp;#10;#trial_num_text = f'turn bonus:\n{current_time_bonus} points'&amp;#10;&amp;#10;# get grid coords and moves&amp;#10;out_x, out_y, possiblemoves = convert_coords(agent2_pos[0], agent2_pos[1], agent='computer')&amp;#10;&amp;#10;flag = True&amp;#10;while flag:&amp;#10;    this_agent2_move = np.random.choice(possiblemoves)&amp;#10;    x_shift, y_shift = convert_moves(this_agent2_move)&amp;#10;&amp;#10;    if ([agent2_pos[0]+x_shift, agent2_pos[1]+y_shift] == chick1_pos):&amp;#10;        flag = True&amp;#10;        possiblemoves.remove(this_agent2_move)&amp;#10;    elif ([agent2_pos[0]+x_shift, agent2_pos[1]+y_shift] == agent1_pos):&amp;#10;        flag = True&amp;#10;        possiblemoves.remove(this_agent2_move)&amp;#10;    else:&amp;#10;        flag = False&amp;#10;&amp;#10;&amp;#10;if this_agent2_move == 'right':&amp;#10;    agent2.flipHoriz = True&amp;#10;&amp;#10;if this_agent2_move == 'left':&amp;#10;    agent2.flipHoriz = False" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="agent2_pos = [(agent2_pos[0] + x_shift), (agent2_pos[1] + y_shift)];&amp;#10;agent2.setPos(agent2_pos, {&quot;log&quot;: true});&amp;#10;agent2_indicator_text.setPos(agent2_pos, {&quot;log&quot;: true});&amp;#10;psychoJS.experiment.addData(`agent2_action`, this_agent2_move);&amp;#10;psychoJS.window.flip();&amp;#10;core.wait(1);&amp;#10;console.log(&quot;agent2&quot;, out_x, out_y, possiblemoves, this_agent2_move, agent2_pos);&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="agent2_pos = [agent2_pos[0]+x_shift, agent2_pos[1]+y_shift]&amp;#10;agent2.setPos(agent2_pos, log=True)&amp;#10;agent2_indicator_text.setPos(agent2_pos, log=True)&amp;#10;&amp;#10;thisExp.addData(f'agent2_action', this_agent2_move)&amp;#10;&amp;#10;win.flip()&amp;#10;core.wait(1)&amp;#10;&amp;#10;print('agent2', out_x, out_y, possiblemoves, this_agent2_move, agent2_pos)" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
