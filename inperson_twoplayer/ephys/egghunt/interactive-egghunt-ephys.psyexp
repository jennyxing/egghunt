        <Param val="# --- Ending &quot;Agents&quot; ---&amp;#10;AgentsComponents = [agent1, agent2, chick1]&amp;#10;if nchicks &gt;= 2:&amp;#10;    AgentsComponents += [chick2]&amp;#10;    &amp;#10;if nchicks &gt;= 3:&amp;#10;    AgentsComponents += [chick3]&amp;#10;    &amp;#10;for thisComponent in AgentsComponents:&amp;#10;    if hasattr(thisComponent, &quot;setAutoDraw&quot;):&amp;#10;        thisComponent.setAutoDraw(False)" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="AgentsComponents = [agent1, agent2, chick1];&amp;#10;if ((nchicks &gt;= 2)) {&amp;#10;    AgentsComponents += [chick2];&amp;#10;}&amp;#10;if ((nchicks &gt;= 3)) {&amp;#10;    AgentsComponents += [chick3];&amp;#10;}&amp;#10;for (var thisComponent, _pj_c = 0, _pj_a = AgentsComponents, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    thisComponent = _pj_a[_pj_c];&amp;#10;    if ((&quot;setAutoDraw&quot; in thisComponent)) {&amp;#10;        thisComponent.setAutoDraw(false);&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="End JS Experiment"/>
