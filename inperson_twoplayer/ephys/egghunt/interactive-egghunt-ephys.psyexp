        <Param val="agent2_pos = [(agent2_pos[0] + x_shift), (agent2_pos[1] + y_shift)];&amp;#10;agent2.setPos(agent2_pos, {&quot;log&quot;: true});&amp;#10;psychoJS.window.flip();&amp;#10;core.wait(1);&amp;#10;console.log(&quot;agent2&quot;, out_x, out_y, possiblemoves, this_agent2_move, agent2_pos);&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
