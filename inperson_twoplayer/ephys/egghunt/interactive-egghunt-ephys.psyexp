      <CodeComponent name="compute_score">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="end_round_time = (globalClock.getTime() - trigger_time);&amp;#10;psychoJS.experiment.addData(&quot;round_end_onset&quot;, end_round_time);&amp;#10;ITI_dur = np.random.uniform(2, 3);&amp;#10;psychoJS.experiment.addData(&quot;ITI&quot;, ITI_dur);&amp;#10;trial_text.setAutoDraw(false);&amp;#10;GridWorldComponents = [diode_square_white, b_0_2, b_0_1, b_3_0, b_2_2, b_1_2, b_2_1, b_2_neg1, b_2_neg2, b_2_0, b_1_neg2, b_1_0, b_0_0, b_neg1_0, b_neg1_2, b_neg1_neg2, b_neg2_0, b_neg2_1, b_neg2_neg1, b_neg2_neg2, b_neg2_2, b_neg3_0, b_0_neg1, b_0_neg2, egg_left, egg_right];&amp;#10;for (var thisComponent, _pj_c = 0, _pj_a = GridWorldComponents, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    thisComponent = _pj_a[_pj_c];&amp;#10;    if ((&quot;setAutoDraw&quot; in thisComponent)) {&amp;#10;        thisComponent.setAutoDraw(false);&amp;#10;    }&amp;#10;}&amp;#10;AgentsComponents = [agent1, agent2, agent1_indicator_text, agent2_indicator_text, chick1];&amp;#10;if ((nchicks &gt;= 2)) {&amp;#10;    AgentsComponents += [chick2];&amp;#10;}&amp;#10;if ((nchicks &gt;= 3)) {&amp;#10;    AgentsComponents += [chick3];&amp;#10;}&amp;#10;for (var thisComponent, _pj_c = 0, _pj_a = AgentsComponents, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    thisComponent = _pj_a[_pj_c];&amp;#10;    if ((&quot;setAutoDraw&quot; in thisComponent)) {&amp;#10;        thisComponent.setAutoDraw(false);&amp;#10;    }&amp;#10;}&amp;#10;if ((agent1_pts &gt; 0)) {&amp;#10;    agent1_complete_text = `PLAYER 1:&amp;#10;+${agent1_pts} points&amp;#10;`&amp;#10;;&amp;#10;} else {&amp;#10;    if ((agent1_pts &lt;= 0)) {&amp;#10;        agent1_complete_text = `PLAYER 1:&amp;#10;${agent1_pts} points&amp;#10;`&amp;#10;;&amp;#10;    }&amp;#10;}&amp;#10;if ((agent2_pts &gt; 0)) {&amp;#10;    agent2_complete_text = `PLAYER 2:&amp;#10;+${agent2_pts} points`&amp;#10;;&amp;#10;} else {&amp;#10;    if ((agent1_pts &lt;= 0)) {&amp;#10;        agent2_complete_text = `PLAYER 2:&amp;#10;${agent2_pts} points`&amp;#10;;&amp;#10;    }&amp;#10;}&amp;#10;round_complete_text = ((`ROUND COMPLETED&amp;#10;`&amp;#10; + agent1_complete_text) + agent2_complete_text);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# store timing:&amp;#10;end_round_time = globalClock.getTime() - trigger_time&amp;#10;thisExp.addData('round_end_onset', end_round_time)&amp;#10;&amp;#10;ITI_dur = np.random.uniform(2,3)&amp;#10;thisExp.addData('ITI', ITI_dur)&amp;#10;&amp;#10;trial_text.setAutoDraw(False)&amp;#10;GridWorldComponents = [diode_square_white, b_0_2, b_0_1, b_3_0, b_2_2, b_1_2, b_2_1, b_2_neg1, b_2_neg2, b_2_0, b_1_neg2, b_1_0, b_0_0, b_neg1_0, b_neg1_2, b_neg1_neg2, b_neg2_0, b_neg2_1, b_neg2_neg1, b_neg2_neg2, b_neg2_2, b_neg3_0, b_0_neg1, b_0_neg2, egg_left, egg_right]&amp;#10;&amp;#10;for thisComponent in GridWorldComponents:&amp;#10;    if hasattr(thisComponent, &quot;setAutoDraw&quot;):&amp;#10;        thisComponent.setAutoDraw(False)&amp;#10;&amp;#10;        &amp;#10;AgentsComponents = [agent1, agent2, agent1_indicator_text, agent2_indicator_text, chick1]&amp;#10;if nchicks &gt;= 2:&amp;#10;    AgentsComponents += [chick2]&amp;#10;&amp;#10;if nchicks &gt;= 3:&amp;#10;    AgentsComponents += [chick3]&amp;#10;    &amp;#10;for thisComponent in AgentsComponents:&amp;#10;    if hasattr(thisComponent, &quot;setAutoDraw&quot;):&amp;#10;        thisComponent.setAutoDraw(False)&amp;#10;&amp;#10;if agent1_pts &gt; 0:&amp;#10;    agent1_complete_text = f'PLAYER 1:\n+{agent1_pts} points\n\n'&amp;#10;elif agent1_pts &lt;= 0:&amp;#10;    agent1_complete_text = f'PLAYER 1:\n{agent1_pts} points\n\n'&amp;#10;&amp;#10;if agent2_pts &gt; 0 :&amp;#10;    agent2_complete_text = f'PLAYER 2:\n+{agent2_pts} points'&amp;#10;elif agent1_pts &lt;= 0:&amp;#10;    agent2_complete_text = f'PLAYER 2:\n{agent2_pts} points'&amp;#10;&amp;#10;round_complete_text = f'ROUND COMPLETED\n\n' + agent1_complete_text + agent2_complete_text" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
