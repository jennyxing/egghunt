        <Param val="if nchicks &gt; 1:&amp;#10;    chick1_instr_txt = 'CHICKEN 1 TURN'&amp;#10;else:&amp;#10;    chick1_instr_txt = 'CHICKEN TURN'&amp;#10;" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="if ((nchicks &gt; 1)) {&amp;#10;    chick1_instr_txt = &quot;CHICKEN 1 TURN&quot;;&amp;#10;} else {&amp;#10;    chick1_instr_txt = &quot;CHICKEN TURN&quot;;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="instr_chick.bold = true;&amp;#10;TrialCount += 1;&amp;#10;current_time_bonus = ((16 - TrialCount) * 10);&amp;#10;trial_num_text = ``;&amp;#10;trial_text.setText(trial_num_text);&amp;#10;trial_text.setAutoDraw(true);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="instr_chick.bold = True&amp;#10;&amp;#10;TrialCount += 1&amp;#10;current_time_bonus = (16 - TrialCount) * 10 # minus 10 pts&amp;#10;&amp;#10;#TurnBonus25 = TurnBonus25 - 25&amp;#10;#current_time_bonus = TurnBonus25 # minus 25 pts&amp;#10;#trial_num_text = f'turn bonus:\n{current_time_bonus} points' # out of {trials.nReps} trials'&amp;#10;trial_num_text = f'' # out of {trials.nReps} trials'&amp;#10;&amp;#10;trial_text.setText(trial_num_text)&amp;#10;trial_text.setAutoDraw(True)" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
