      <CodeComponent name="change_agent1">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="agent1_jitter = np.random.uniform(1, 1.5);&amp;#10;psychoJS.experiment.addData(&quot;agent1_jitter&quot;, agent1_jitter);&amp;#10;instr_agent1.bold = true;&amp;#10;agent1_indicator_text.color = &quot;red&quot;;&amp;#10;[out_x, out_y, possiblemoves] = convert_coords(agent1_pos[0], agent1_pos[1], {&quot;agent&quot;: &quot;player1&quot;});&amp;#10;for (var this_move, _pj_c = 0, _pj_a = possiblemoves, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    this_move = _pj_a[_pj_c];&amp;#10;    [x_shift, y_shift] = convert_moves(this_move);&amp;#10;    if (([(agent1_pos[0] + x_shift), (agent1_pos[1] + y_shift)] === chick1_pos)) {&amp;#10;        possiblemoves.remove(this_move);&amp;#10;    }&amp;#10;    if (([(agent1_pos[0] + x_shift), (agent1_pos[1] + y_shift)] === agent2_pos)) {&amp;#10;        possiblemoves.remove(this_move);&amp;#10;    }&amp;#10;}&amp;#10;this_agent1_move = &quot;&quot;;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="agent1_jitter = np.random.uniform(1,1.5)&amp;#10;thisExp.addData('agent1_jitter', agent1_jitter)&amp;#10;&amp;#10;instr_agent1.bold = True&amp;#10;agent1_indicator_text.color = &quot;red&quot;&amp;#10;&amp;#10;# get grid coords and moves&amp;#10;out_x, out_y, possiblemoves = convert_coords(agent1_pos[0], agent1_pos[1], agent='player1')&amp;#10;&amp;#10;# remove possible move if adjacent to another agent&amp;#10;for this_move in possiblemoves:&amp;#10;    x_shift, y_shift = convert_moves(this_move)&amp;#10;    if [agent1_pos[0]+x_shift, agent1_pos[1]+y_shift] == chick1_pos:&amp;#10;        possiblemoves.remove(this_move)&amp;#10;    if [agent1_pos[0]+x_shift, agent1_pos[1]+y_shift] == agent2_pos:&amp;#10;        possiblemoves.remove(this_move)&amp;#10;&amp;#10;this_agent1_move = ''" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="current_agent1_keyresp = resp_agent1.getKeys(clear=True)&amp;#10;if current_agent1_keyresp:&amp;#10;     if resp_agent1.keys in possiblemoves:&amp;#10;        if resp_agent1.keys == 'h':&amp;#10;            this_agent1_move = 'left'&amp;#10;            agent1_pos = [agent1_pos[0]-.15, agent1_pos[1]]&amp;#10;            agent1.image = agent1_imgs['left']&amp;#10;            &amp;#10;            # store timing:&amp;#10;            agent1_move_onset_time = globalClock.getTime() - trigger_time&amp;#10;            thisExp.addData('agent1_move_onset', agent1_move_onset_time)&amp;#10;            &amp;#10;            agent1_move_since_round_start = globalClock.getTime() - round_start_time&amp;#10;            thisExp.addData('agent1_move_onset_from_round_start', agent1_move_since_round_start)&amp;#10;&amp;#10;            win.flip()&amp;#10;        elif resp_agent1.keys == 'k':&amp;#10;            this_agent1_move = 'right'&amp;#10;            agent1_pos = [agent1_pos[0]+.15, agent1_pos[1]]&amp;#10;            agent1.image = agent1_imgs['right']&amp;#10;            &amp;#10;            # store timing:&amp;#10;            agent1_move_onset_time = globalClock.getTime() - trigger_time&amp;#10;            thisExp.addData('agent1_move_onset', agent1_move_onset_time)&amp;#10;            &amp;#10;            agent1_move_since_round_start = globalClock.getTime() - round_start_time&amp;#10;            thisExp.addData('agent1_move_onset_from_round_start', agent1_move_since_round_start)&amp;#10;&amp;#10;            win.flip()&amp;#10;        elif resp_agent1.keys == 'u':&amp;#10;            this_agent1_move = 'up'&amp;#10;            agent1_pos = [agent1_pos[0], agent1_pos[1]+.15]&amp;#10;            agent1.image = agent1_imgs['up']&amp;#10;            &amp;#10;            # store timing:&amp;#10;            agent1_move_onset_time = globalClock.getTime() - trigger_time&amp;#10;            thisExp.addData('agent1_move_onset', agent1_move_onset_time)&amp;#10;            &amp;#10;            agent1_move_since_round_start = globalClock.getTime() - round_start_time&amp;#10;            thisExp.addData('agent1_move_onset_from_round_start', agent1_move_since_round_start)&amp;#10;&amp;#10;            win.flip()&amp;#10;        elif resp_agent1.keys == 'n':&amp;#10;            this_agent1_move = 'down'&amp;#10;            agent1_pos = [agent1_pos[0], agent1_pos[1]-.15]&amp;#10;            agent1.image = agent1_imgs['down']&amp;#10;            &amp;#10;            # store timing:&amp;#10;            agent1_move_onset_time = globalClock.getTime() - trigger_time&amp;#10;            thisExp.addData('agent1_move_onset', agent1_move_onset_time)&amp;#10;            &amp;#10;            agent1_move_since_round_start = globalClock.getTime() - round_start_time&amp;#10;            thisExp.addData('agent1_move_onset_from_round_start', agent1_move_since_round_start)&amp;#10;&amp;#10;            win.flip()&amp;#10;        else:&amp;#10;            this_agent1_move = 'null'&amp;#10;            agent1.image = agent1_imgs['down']&amp;#10;            &amp;#10;            # store timing:&amp;#10;            agent1_move_onset_time = globalClock.getTime() - trigger_time&amp;#10;            thisExp.addData('agent1_move_onset', agent1_move_onset_time)&amp;#10;            &amp;#10;            agent1_move_since_round_start = globalClock.getTime() - round_start_time&amp;#10;            thisExp.addData('agent1_move_onset_from_round_start', agent1_move_since_round_start)&amp;#10;&amp;#10;            win.flip()&amp;#10;            &amp;#10;        agent1.setPos(agent1_pos, log=True)&amp;#10;        agent1_indicator_text.setPos(agent1_pos, log=True)&amp;#10;        &amp;#10;        if agent1_pos[0] &gt; .3:&amp;#10;            egg_right.setAutoDraw(False)&amp;#10;        if agent1_pos[0] &lt; -.3:&amp;#10;            egg_left.setAutoDraw(False)&amp;#10;        win.flip()&amp;#10;        continueRoutine = False" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="var _pj;&amp;#10;function _pj_snippets(container) {&amp;#10;    function in_es6(left, right) {&amp;#10;        if (((right instanceof Array) || ((typeof right) === &quot;string&quot;))) {&amp;#10;            return (right.indexOf(left) &gt; (- 1));&amp;#10;        } else {&amp;#10;            if (((right instanceof Map) || (right instanceof Set) || (right instanceof WeakMap) || (right instanceof WeakSet))) {&amp;#10;                return right.has(left);&amp;#10;            } else {&amp;#10;                return (left in right);&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    container[&quot;in_es6&quot;] = in_es6;&amp;#10;    return container;&amp;#10;}&amp;#10;_pj = {};&amp;#10;_pj_snippets(_pj);&amp;#10;current_agent1_keyresp = resp_agent1.getKeys({&quot;clear&quot;: true});&amp;#10;if (current_agent1_keyresp) {&amp;#10;    if (_pj.in_es6(resp_agent1.keys, possiblemoves)) {&amp;#10;        if ((resp_agent1.keys === &quot;h&quot;)) {&amp;#10;            this_agent1_move = &quot;left&quot;;&amp;#10;            agent1_pos = [(agent1_pos[0] - 0.15), agent1_pos[1]];&amp;#10;            agent1.image = agent1_imgs[&quot;left&quot;];&amp;#10;            agent1_move_onset_time = (globalClock.getTime() - trigger_time);&amp;#10;            psychoJS.experiment.addData(&quot;agent1_move_onset&quot;, agent1_move_onset_time);&amp;#10;            agent1_move_since_round_start = (globalClock.getTime() - round_start_time);&amp;#10;            psychoJS.experiment.addData(&quot;agent1_move_onset_from_round_start&quot;, agent1_move_since_round_start);&amp;#10;            psychoJS.window.flip();&amp;#10;        } else {&amp;#10;            if ((resp_agent1.keys === &quot;k&quot;)) {&amp;#10;                this_agent1_move = &quot;right&quot;;&amp;#10;                agent1_pos = [(agent1_pos[0] + 0.15), agent1_pos[1]];&amp;#10;                agent1.image = agent1_imgs[&quot;right&quot;];&amp;#10;                agent1_move_onset_time = (globalClock.getTime() - trigger_time);&amp;#10;                psychoJS.experiment.addData(&quot;agent1_move_onset&quot;, agent1_move_onset_time);&amp;#10;                agent1_move_since_round_start = (globalClock.getTime() - round_start_time);&amp;#10;                psychoJS.experiment.addData(&quot;agent1_move_onset_from_round_start&quot;, agent1_move_since_round_start);&amp;#10;                psychoJS.window.flip();&amp;#10;            } else {&amp;#10;                if ((resp_agent1.keys === &quot;u&quot;)) {&amp;#10;                    this_agent1_move = &quot;up&quot;;&amp;#10;                    agent1_pos = [agent1_pos[0], (agent1_pos[1] + 0.15)];&amp;#10;                    agent1.image = agent1_imgs[&quot;up&quot;];&amp;#10;                    agent1_move_onset_time = (globalClock.getTime() - trigger_time);&amp;#10;                    psychoJS.experiment.addData(&quot;agent1_move_onset&quot;, agent1_move_onset_time);&amp;#10;                    agent1_move_since_round_start = (globalClock.getTime() - round_start_time);&amp;#10;                    psychoJS.experiment.addData(&quot;agent1_move_onset_from_round_start&quot;, agent1_move_since_round_start);&amp;#10;                    psychoJS.window.flip();&amp;#10;                } else {&amp;#10;                    if ((resp_agent1.keys === &quot;n&quot;)) {&amp;#10;                        this_agent1_move = &quot;down&quot;;&amp;#10;                        agent1_pos = [agent1_pos[0], (agent1_pos[1] - 0.15)];&amp;#10;                        agent1.image = agent1_imgs[&quot;down&quot;];&amp;#10;                        agent1_move_onset_time = (globalClock.getTime() - trigger_time);&amp;#10;                        psychoJS.experiment.addData(&quot;agent1_move_onset&quot;, agent1_move_onset_time);&amp;#10;                        agent1_move_since_round_start = (globalClock.getTime() - round_start_time);&amp;#10;                        psychoJS.experiment.addData(&quot;agent1_move_onset_from_round_start&quot;, agent1_move_since_round_start);&amp;#10;                        psychoJS.window.flip();&amp;#10;                    } else {&amp;#10;                        this_agent1_move = &quot;null&quot;;&amp;#10;                        agent1.image = agent1_imgs[&quot;down&quot;];&amp;#10;                        agent1_move_onset_time = (globalClock.getTime() - trigger_time);&amp;#10;                        psychoJS.experiment.addData(&quot;agent1_move_onset&quot;, agent1_move_onset_time);&amp;#10;                        agent1_move_since_round_start = (globalClock.getTime() - round_start_time);&amp;#10;                        psychoJS.experiment.addData(&quot;agent1_move_onset_from_round_start&quot;, agent1_move_since_round_start);&amp;#10;                        psychoJS.window.flip();&amp;#10;                    }&amp;#10;                }&amp;#10;            }&amp;#10;        }&amp;#10;        agent1.setPos(agent1_pos, {&quot;log&quot;: true});&amp;#10;        agent1_indicator_text.setPos(agent1_pos, {&quot;log&quot;: true});&amp;#10;        if ((agent1_pos[0] &gt; 0.3)) {&amp;#10;            egg_right.setAutoDraw(false);&amp;#10;        }&amp;#10;        if ((agent1_pos[0] &lt; (- 0.3))) {&amp;#10;            egg_left.setAutoDraw(false);&amp;#10;        }&amp;#10;        psychoJS.window.flip();&amp;#10;        continueRoutine = false;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="var _pj;&amp;#10;function _pj_snippets(container) {&amp;#10;    function in_es6(left, right) {&amp;#10;        if (((right instanceof Array) || ((typeof right) === &quot;string&quot;))) {&amp;#10;            return (right.indexOf(left) &gt; (- 1));&amp;#10;        } else {&amp;#10;            if (((right instanceof Map) || (right instanceof Set) || (right instanceof WeakMap) || (right instanceof WeakSet))) {&amp;#10;                return right.has(left);&amp;#10;            } else {&amp;#10;                return (left in right);&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    container[&quot;in_es6&quot;] = in_es6;&amp;#10;    return container;&amp;#10;}&amp;#10;_pj = {};&amp;#10;_pj_snippets(_pj);&amp;#10;if (_pj.in_es6(this_agent1_move, [&quot;up&quot;, &quot;down&quot;, &quot;left&quot;, &quot;right&quot;])) {&amp;#10;    psychoJS.experiment.addData(`agent1_action`, this_agent1_move);&amp;#10;} else {&amp;#10;    psychoJS.experiment.addData(`agent1_action`, &quot;null&quot;);&amp;#10;}&amp;#10;core.wait(agent1_jitter);&amp;#10;agent1.image = agent1_imgs[&quot;down&quot;];&amp;#10;psychoJS.window.flip();&amp;#10;agent1_indicator_text.color = &quot;black&quot;;&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="#print('agent1', out_x, out_y, possiblemoves, resp_agent1.keys, agent1_pos)&amp;#10;&amp;#10;if this_agent1_move in ['up','down','left','right']:&amp;#10;    thisExp.addData(f'agent1_action', this_agent1_move)&amp;#10;else:&amp;#10;    thisExp.addData(f'agent1_action', 'null')&amp;#10;&amp;#10;core.wait(agent1_jitter)&amp;#10;agent1.image = agent1_imgs['down']&amp;#10;win.flip()&amp;#10;&amp;#10;agent1_indicator_text.color = &quot;black&quot;" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="change_agent1" valType="code" updates="None" name="name"/>
      </CodeComponent>
    </Routine>
    <Routine name="start_round">
      <CodeComponent name="reposition">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if ((firstplayer === &quot;player1&quot;)) {&amp;#10;    player1_turn = 1;&amp;#10;    player2_turn = 0;&amp;#10;    PLAYER_START_TEXT = &quot;\nPLAYER 1 GOES FIRST&quot;;&amp;#10;    PLAYER_START_IMG = agent1_imgs[&quot;down&quot;];&amp;#10;} else {&amp;#10;    if ((firstplayer === &quot;player2&quot;)) {&amp;#10;        player1_turn = 0;&amp;#10;        player2_turn = 1;&amp;#10;        PLAYER_START_TEXT = &quot;\nPLAYER 2 GOES FIRST&quot;;&amp;#10;        PLAYER_START_IMG = agent2_imgs[&quot;down&quot;];&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# check who goes first&amp;#10;if firstplayer == 'player1':&amp;#10;    player1_turn = 1&amp;#10;    player2_turn = 0&amp;#10;    PLAYER_START_TEXT = '\nPLAYER 1 GOES FIRST'&amp;#10;    PLAYER_START_IMG = agent1_imgs['down']&amp;#10;elif firstplayer == 'player2':&amp;#10;    player1_turn = 0&amp;#10;    player2_turn = 1&amp;#10;    PLAYER_START_TEXT = '\nPLAYER 2 GOES FIRST'&amp;#10;    PLAYER_START_IMG = agent2_imgs['down']&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
