    <Routine name="end_turns">
      <CodeComponent name="check_end">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="var _pj;&amp;#10;function _pj_snippets(container) {&amp;#10;    function in_es6(left, right) {&amp;#10;        if (((right instanceof Array) || ((typeof right) === &quot;string&quot;))) {&amp;#10;            return (right.indexOf(left) &gt; (- 1));&amp;#10;        } else {&amp;#10;            if (((right instanceof Map) || (right instanceof Set) || (right instanceof WeakMap) || (right instanceof WeakSet))) {&amp;#10;                return right.has(left);&amp;#10;            } else {&amp;#10;                return (left in right);&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    container[&quot;in_es6&quot;] = in_es6;&amp;#10;    return container;&amp;#10;}&amp;#10;_pj = {};&amp;#10;_pj_snippets(_pj);&amp;#10;agent1_pts = (0 + current_time_bonus);&amp;#10;agent2_pts = (0 + current_time_bonus);&amp;#10;if (((Math.abs(agent2_pos[0]) &gt; 0.35) &amp;&amp; (Math.abs(agent1_pos[0]) &gt; 0.35))) {&amp;#10;    agent1_pts = (100 + current_time_bonus);&amp;#10;    agent2_pts = (100 + current_time_bonus);&amp;#10;    trials.nReps = 0;&amp;#10;    trials.Finished = true;&amp;#10;    endLoop = 1;&amp;#10;    psychoJS.experiment.addData(&quot;outcome&quot;, &quot;both defect&quot;);&amp;#10;    console.log(&quot;ending agent 1+2&quot;);&amp;#10;} else {&amp;#10;    if ((Math.abs(agent1_pos[0]) &gt; 0.35)) {&amp;#10;        agent1_pts = (100 + current_time_bonus);&amp;#10;        agent2_pts = (0 + current_time_bonus);&amp;#10;        trials.nReps = 0;&amp;#10;        trials.Finished = true;&amp;#10;        endLoop = 1;&amp;#10;        psychoJS.experiment.addData(&quot;outcome&quot;, &quot;agent1 defect&quot;);&amp;#10;        console.log(&quot;ending agent 1&quot;);&amp;#10;    } else {&amp;#10;        if ((Math.abs(agent2_pos[0]) &gt; 0.35)) {&amp;#10;            agent1_pts = (0 + current_time_bonus);&amp;#10;            agent2_pts = (100 + current_time_bonus);&amp;#10;            trials.nReps = 0;&amp;#10;            trials.Finished = true;&amp;#10;            endLoop = 1;&amp;#10;            psychoJS.experiment.addData(&quot;outcome&quot;, &quot;agent2 defect&quot;);&amp;#10;            console.log(&quot;ending agent 2&quot;);&amp;#10;        } else {&amp;#10;            psychoJS.experiment.addData(&quot;outcome&quot;, &quot;none&quot;);&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;if ((endLoop !== 1)) {&amp;#10;    adjacent_spaces1 = get_adjacent_tiles(chick1_pos[0], chick1_pos[1]);&amp;#10;    console.log(adjacent_spaces1);&amp;#10;    agent1_hunt1 = false;&amp;#10;    if (_pj.in_es6(agent1_pos, adjacent_spaces1)) {&amp;#10;        agent1_hunt1 = true;&amp;#10;        psychoJS.experiment.addData(&quot;agent1_nexttochick&quot;, 1);&amp;#10;        console.log(&quot;agent 1 hunt 1&quot;);&amp;#10;    } else {&amp;#10;        psychoJS.experiment.addData(&quot;agent1_nexttochick&quot;, 0);&amp;#10;    }&amp;#10;    agent2_hunt1 = false;&amp;#10;    if (_pj.in_es6(agent2_pos, adjacent_spaces1)) {&amp;#10;        agent2_hunt1 = true;&amp;#10;        psychoJS.experiment.addData(&quot;agent2_nexttochick&quot;, 1);&amp;#10;        console.log(&quot;agent 2 hunt 2&quot;);&amp;#10;    } else {&amp;#10;        psychoJS.experiment.addData(&quot;agent2_nexttochick&quot;, 0);&amp;#10;    }&amp;#10;    if ((nchicks === 1)) {&amp;#10;        if ((agent1_hunt1 &amp;&amp; agent2_hunt1)) {&amp;#10;            agent1_pts = (200 + current_time_bonus);&amp;#10;            agent2_pts = (200 + current_time_bonus);&amp;#10;            trials.nReps = 0;&amp;#10;            trials.Finished = true;&amp;#10;            endLoop = 1;&amp;#10;            psychoJS.experiment.addData(&quot;outcome&quot;, &quot;cooperate&quot;);&amp;#10;            console.log(&quot;ending agent 1+2&quot;);&amp;#10;        }&amp;#10;    }&amp;#10;    if ((nchicks &gt;= 2)) {&amp;#10;        adjacent_spaces2 = get_adjacent_tiles(chick2_pos[0], chick2_pos[1]);&amp;#10;        console.log(adjacent_spaces2);&amp;#10;        agent1_hunt2 = false;&amp;#10;        if (_pj.in_es6(agent1_pos, adjacent_spaces2)) {&amp;#10;            agent1_hunt2 = true;&amp;#10;            console.log(&quot;agent 1 hunt 2&quot;);&amp;#10;        }&amp;#10;        agent2_hunt2 = false;&amp;#10;        if (_pj.in_es6(agent2_pos, adjacent_spaces2)) {&amp;#10;            agent2_hunt2 = true;&amp;#10;            console.log(&quot;agent 2 hunt 2&quot;);&amp;#10;        }&amp;#10;        if ((agent1_hunt1 &amp;&amp; agent2_hunt1)) {&amp;#10;            agent1_pts = (500 + current_time_bonus);&amp;#10;            agent2_pts = (200 + current_time_bonus);&amp;#10;            trials.nReps = 0;&amp;#10;            trials.Finished = true;&amp;#10;            endLoop = 1;&amp;#10;            console.log(&quot;ending agent 1+2&quot;);&amp;#10;        }&amp;#10;        if ((agent1_hunt2 &amp;&amp; agent2_hunt2)) {&amp;#10;            agent1_pts = (200 + current_time_bonus);&amp;#10;            agent2_pts = (500 + current_time_bonus);&amp;#10;            trials.nReps = 0;&amp;#10;            trials.Finished = true;&amp;#10;            endLoop = 1;&amp;#10;            console.log(&quot;ending agent 1+2&quot;);&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;psychoJS.experiment.addData(&quot;agent1_pts&quot;, agent1_pts);&amp;#10;psychoJS.experiment.addData(&quot;agent2_pts&quot;, agent2_pts);&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="agent1_pts = 0 + current_time_bonus&amp;#10;agent2_pts = 0 + current_time_bonus&amp;#10;&amp;#10;if (abs(agent2_pos[0]) &gt; .35) and (abs(agent1_pos[0]) &gt; .35):&amp;#10;    agent1_pts = 100 + current_time_bonus&amp;#10;    agent2_pts = 100 + current_time_bonus&amp;#10;    trials.nReps = 0&amp;#10;    trials.Finished = True&amp;#10;    endLoop = 1&amp;#10;    thisExp.addData('outcome', 'both defect')&amp;#10;    print('ending agent 1+2')&amp;#10;elif (abs(agent1_pos[0]) &gt; .35):&amp;#10;    agent1_pts = 100 + current_time_bonus&amp;#10;    agent2_pts = 0 + current_time_bonus&amp;#10;    trials.nReps = 0&amp;#10;    trials.Finished = True&amp;#10;    endLoop = 1&amp;#10;    thisExp.addData('outcome', 'agent1 defect')&amp;#10;    print('ending agent 1')&amp;#10;elif (abs(agent2_pos[0]) &gt; .35):&amp;#10;    agent1_pts = 0 + current_time_bonus&amp;#10;    agent2_pts = 100 + current_time_bonus&amp;#10;    trials.nReps = 0&amp;#10;    trials.Finished = True&amp;#10;    endLoop = 1&amp;#10;    thisExp.addData('outcome', 'agent2 defect')&amp;#10;    print('ending agent 2')&amp;#10;else:&amp;#10;    thisExp.addData('outcome', 'none')&amp;#10;    &amp;#10;if endLoop != 1:&amp;#10;    # compute chick 1 coords&amp;#10;    adjacent_spaces1 = get_adjacent_tiles(chick1_pos[0], chick1_pos[1])&amp;#10;    print(adjacent_spaces1)&amp;#10;    &amp;#10;    agent1_hunt1 = False&amp;#10;    if agent1_pos in adjacent_spaces1:&amp;#10;        agent1_hunt1 = True&amp;#10;        thisExp.addData('agent1_nexttochick', 1)&amp;#10;        print('agent 1 hunt 1')&amp;#10;    else:&amp;#10;        thisExp.addData('agent1_nexttochick', 0)&amp;#10;        &amp;#10;    agent2_hunt1 = False&amp;#10;    if agent2_pos in adjacent_spaces1:&amp;#10;        agent2_hunt1 = True&amp;#10;        thisExp.addData('agent2_nexttochick', 1)&amp;#10;        print('agent 2 hunt 2')&amp;#10;    else:&amp;#10;        thisExp.addData('agent2_nexttochick', 0)&amp;#10;    &amp;#10;    if nchicks == 1:&amp;#10;        if agent1_hunt1 and agent2_hunt1:&amp;#10;            agent1_pts = 200 + current_time_bonus&amp;#10;            agent2_pts = 200 + current_time_bonus&amp;#10;            trials.nReps = 0&amp;#10;            trials.Finished = True&amp;#10;            endLoop = 1&amp;#10;            thisExp.addData('outcome', 'cooperate')&amp;#10;            print('ending agent 1+2')&amp;#10;&amp;#10;    if nchicks &gt;= 2:&amp;#10;        adjacent_spaces2 = get_adjacent_tiles(chick2_pos[0], chick2_pos[1])&amp;#10;        print(adjacent_spaces2)&amp;#10;        &amp;#10;        agent1_hunt2 = False&amp;#10;        if agent1_pos in adjacent_spaces2:&amp;#10;            agent1_hunt2 = True&amp;#10;            print('agent 1 hunt 2')&amp;#10;            &amp;#10;        agent2_hunt2 = False&amp;#10;        if agent2_pos in adjacent_spaces2:&amp;#10;            agent2_hunt2 = True&amp;#10;            print('agent 2 hunt 2')&amp;#10;        &amp;#10;        if agent1_hunt1 and agent2_hunt1:&amp;#10;            agent1_pts = 500 + current_time_bonus&amp;#10;            agent2_pts = 200 + current_time_bonus&amp;#10;            trials.nReps = 0&amp;#10;            trials.Finished = True&amp;#10;            endLoop = 1&amp;#10;            print('ending agent 1+2')&amp;#10;            &amp;#10;        if agent1_hunt2 and agent2_hunt2:&amp;#10;            agent1_pts = 200 + current_time_bonus&amp;#10;            agent2_pts = 500 + current_time_bonus&amp;#10;            trials.nReps = 0&amp;#10;            trials.Finished = True&amp;#10;            endLoop = 1&amp;#10;            print('ending agent 1+2')&amp;#10;&amp;#10;thisExp.addData('agent1_pts', agent1_pts)&amp;#10;thisExp.addData('agent2_pts', agent2_pts)&amp;#10;" valType="extendedCode" updates="constant" name="End Routine"/>
