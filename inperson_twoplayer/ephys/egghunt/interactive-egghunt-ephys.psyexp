      </CodeComponent>
      <CodeComponent name="change_chick">
        <Param val="def maximize_chick_distance(agent0_pos, agent1_pos, agent2_pos, possiblemoves, use_nsteps=True):&amp;#10;    max_distance = 0&amp;#10;    best_move = None&amp;#10;    &amp;#10;    move_dict = {'left': (-.15, 0), &amp;#10;                 'right': (.15, 0), &amp;#10;                 'up': (0, .15), &amp;#10;                 'down': (0, -.15), &amp;#10;                 'space': (0, 0)}&amp;#10;    &amp;#10;    new_possible_moves = []&amp;#10;    for move in possiblemoves: &amp;#10;        if use_nsteps: # Manhattan distance to move according to number of steps&amp;#10;            distance1 = abs(agent0_pos[0] + move_dict[move][0] - agent1_pos[0]) + abs(agent0_pos[1] + move_dict[move][1] - agent1_pos[1]) &amp;#10;            distance2 = abs(agent0_pos[0] + move_dict[move][0] - agent2_pos[0]) + abs(agent0_pos[1] + move_dict[move][1] - agent2_pos[1])&amp;#10;            distance = np.round(distance1 + distance2, 4)&amp;#10;&amp;#10;        else: #Euclidean distance&amp;#10;            distance1 = ((agent0_pos[0] + move_dict[move][0] - agent1_pos[0]) ** 2 + (agent0_pos[1] + move_dict[move][1] - agent1_pos[1]) ** 2) ** 0.5 &amp;#10;            distance2 = ((agent0_pos[0] + move_dict[move][0] - agent2_pos[0]) ** 2 + (agent0_pos[1] + move_dict[move][1] - agent2_pos[1]) ** 2) ** 0.5&amp;#10;            distance = np.round(distance1 + distance2, 4)&amp;#10;&amp;#10;        print(move, distance1, distance2, distance)&amp;#10;&amp;#10;        # if move maximizes distance, then store&amp;#10;        # moves to maximize distance if the move does not place chicken next to agent&amp;#10;        # if multiple moves are equal in distance, then chooses randomly among them&amp;#10;        &amp;#10;        if max_distance == 0:&amp;#10;            first_move_in_list, first_dist_in_list = move, distance&amp;#10;&amp;#10;        if distance1 &gt; .15 and distance2 &gt; .15:&amp;#10;            if distance &gt;= max_distance:&amp;#10;                if distance == max_distance or max_distance == 0:&amp;#10;                    # how to choose if all dists are equal:&amp;#10;                    if move == 'space':&amp;#10;                        if distance1 &lt; .15 or distance2 &lt; .15:&amp;#10;                            continue&amp;#10;                        else:&amp;#10;                            new_possible_moves.append(move)&amp;#10;&amp;#10;                    else: &amp;#10;                        if max_distance == 0:&amp;#10;                            max_distance = distance&amp;#10;                            best_move = move&amp;#10;                        else:&amp;#10;                            new_possible_moves.append(move)&amp;#10;                else:&amp;#10;                    max_distance = distance&amp;#10;                    best_move = move&amp;#10;&amp;#10;    if first_dist_in_list == max_distance:&amp;#10;        new_possible_moves.append(first_move_in_list)&amp;#10;&amp;#10;    if len(new_possible_moves) &gt; 0:&amp;#10;        best_move = np.random.choice(new_possible_moves)&amp;#10;    &amp;#10;    if best_move is None:&amp;#10;        best_move = 'space'&amp;#10;        &amp;#10;    print(new_possible_moves)&amp;#10;    print(best_move)&amp;#10;            &amp;#10;    return best_move" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="function maximize_chick_distance(agent0_pos, agent1_pos, agent2_pos, possiblemoves, use_nsteps = true) {&amp;#10;    var best_move, distance, distance1, distance2, first_dist_in_list, first_move_in_list, max_distance, move_dict, new_possible_moves;&amp;#10;    max_distance = 0;&amp;#10;    best_move = null;&amp;#10;    move_dict = {&quot;left&quot;: [(- 0.15), 0], &quot;right&quot;: [0.15, 0], &quot;up&quot;: [0, 0.15], &quot;down&quot;: [0, (- 0.15)], &quot;space&quot;: [0, 0]};&amp;#10;    new_possible_moves = [];&amp;#10;    for (var move, _pj_c = 0, _pj_a = possiblemoves, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;        move = _pj_a[_pj_c];&amp;#10;        if (use_nsteps) {&amp;#10;            distance1 = (Math.abs(((agent0_pos[0] + move_dict[move][0]) - agent1_pos[0])) + Math.abs(((agent0_pos[1] + move_dict[move][1]) - agent1_pos[1])));&amp;#10;            distance2 = (Math.abs(((agent0_pos[0] + move_dict[move][0]) - agent2_pos[0])) + Math.abs(((agent0_pos[1] + move_dict[move][1]) - agent2_pos[1])));&amp;#10;            distance = np.round((distance1 + distance2), 4);&amp;#10;        } else {&amp;#10;            distance1 = Math.pow((Math.pow(((agent0_pos[0] + move_dict[move][0]) - agent1_pos[0]), 2) + Math.pow(((agent0_pos[1] + move_dict[move][1]) - agent1_pos[1]), 2)), 0.5);&amp;#10;            distance2 = Math.pow((Math.pow(((agent0_pos[0] + move_dict[move][0]) - agent2_pos[0]), 2) + Math.pow(((agent0_pos[1] + move_dict[move][1]) - agent2_pos[1]), 2)), 0.5);&amp;#10;            distance = np.round((distance1 + distance2), 4);&amp;#10;        }&amp;#10;        console.log(move, distance1, distance2, distance);&amp;#10;        if ((max_distance === 0)) {&amp;#10;            [first_move_in_list, first_dist_in_list] = [move, distance];&amp;#10;        }&amp;#10;        if (((distance1 &gt; 0.15) &amp;&amp; (distance2 &gt; 0.15))) {&amp;#10;            if ((distance &gt;= max_distance)) {&amp;#10;                if (((distance === max_distance) || (max_distance === 0))) {&amp;#10;                    if ((move === &quot;space&quot;)) {&amp;#10;                        if (((distance1 &lt; 0.15) || (distance2 &lt; 0.15))) {&amp;#10;                            continue;&amp;#10;                        } else {&amp;#10;                            new_possible_moves.push(move);&amp;#10;                        }&amp;#10;                    } else {&amp;#10;                        if ((max_distance === 0)) {&amp;#10;                            max_distance = distance;&amp;#10;                            best_move = move;&amp;#10;                        } else {&amp;#10;                            new_possible_moves.push(move);&amp;#10;                        }&amp;#10;                    }&amp;#10;                } else {&amp;#10;                    max_distance = distance;&amp;#10;                    best_move = move;&amp;#10;                }&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    if ((first_dist_in_list === max_distance)) {&amp;#10;        new_possible_moves.push(first_move_in_list);&amp;#10;    }&amp;#10;    if ((new_possible_moves.length &gt; 0)) {&amp;#10;        best_move = np.random.choice(new_possible_moves);&amp;#10;    }&amp;#10;    if ((best_move === null)) {&amp;#10;        best_move = &quot;space&quot;;&amp;#10;    }&amp;#10;    console.log(new_possible_moves);&amp;#10;    console.log(best_move);&amp;#10;    return best_move;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="chick_jitter = np.random.uniform(2, 3);&amp;#10;psychoJS.experiment.addData(&quot;chick_jitter&quot;, chick_jitter);&amp;#10;chick_timer = new core.Clock();&amp;#10;[out_x, out_y, possiblemoves] = convert_coords(chick1_pos[0], chick1_pos[1], {&quot;agent&quot;: &quot;computer&quot;});&amp;#10;if ((((chick1_pos[0] === agent2_pos[0]) &amp;&amp; (chick1_pos[1] === agent2_pos[1])) || ((chick1_pos[0] === agent1_pos[0]) &amp;&amp; (chick1_pos[1] === agent1_pos[1])))) {&amp;#10;    possiblemoves.remove(&quot;space&quot;);&amp;#10;}&amp;#10;flag = true;&amp;#10;while (flag) {&amp;#10;    this_chick1_move = maximize_chick_distance(chick1_pos, agent1_pos, agent2_pos, possiblemoves);&amp;#10;    [x_shift, y_shift] = convert_moves(this_chick1_move);&amp;#10;    if ((nchicks &gt;= 2)) {&amp;#10;        if (((([(chick1_pos[0] + x_shift), (chick1_pos[1] + y_shift)] === agent2_pos) || ([(chick1_pos[0] + x_shift), (chick1_pos[1] + y_shift)] === chick2_pos)) || ([(chick1_pos[0] + x_shift), (chick1_pos[1] + y_shift)] === agent1_pos))) {&amp;#10;            flag = true;&amp;#10;            possiblemoves.remove(this_chick1_move);&amp;#10;        } else {&amp;#10;            if ((Math.abs((chick1_pos[0] + x_shift)) &gt; 0.35)) {&amp;#10;                flag = true;&amp;#10;                possiblemoves.remove(this_chick1_move);&amp;#10;            } else {&amp;#10;                flag = false;&amp;#10;            }&amp;#10;        }&amp;#10;    } else {&amp;#10;        if ((nchicks === 1)) {&amp;#10;            if ((([(chick1_pos[0] + x_shift), (chick1_pos[1] + y_shift)] === agent2_pos) || ([(chick1_pos[0] + x_shift), (chick1_pos[1] + y_shift)] === agent1_pos))) {&amp;#10;                flag = true;&amp;#10;                possiblemoves.remove(&quot;space&quot;);&amp;#10;                possiblemoves.remove(this_chick1_move);&amp;#10;            } else {&amp;#10;                if ((Math.abs((chick1_pos[0] + x_shift)) &gt; 0.35)) {&amp;#10;                    flag = true;&amp;#10;                    possiblemoves.remove(this_chick1_move);&amp;#10;                } else {&amp;#10;                    flag = false;&amp;#10;                }&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="chick_jitter = np.random.uniform(2,3)&amp;#10;thisExp.addData('chick_jitter', chick_jitter)&amp;#10;chick_timer = core.Clock()&amp;#10;&amp;#10;# get grid coords and moves&amp;#10;out_x, out_y, possiblemoves = convert_coords(chick1_pos[0], chick1_pos[1], agent='computer')&amp;#10;&amp;#10;# NEED TO EDIT THIS&amp;#10;if (chick1_pos[0]== agent2_pos[0] and chick1_pos[1] == agent2_pos[1]) or (chick1_pos[0]== agent1_pos[0] and chick1_pos[1] == agent1_pos[1]):&amp;#10;    possiblemoves.remove('space')&amp;#10;    &amp;#10;flag = True&amp;#10;while flag:&amp;#10;    #this_chick1_move = np.random.choice(possiblemoves)&amp;#10;    this_chick1_move = maximize_chick_distance(chick1_pos, agent1_pos, agent2_pos, possiblemoves)&amp;#10;    x_shift, y_shift = convert_moves(this_chick1_move)&amp;#10;    &amp;#10;    if nchicks &gt;= 2:&amp;#10;        if ([chick1_pos[0]+x_shift, chick1_pos[1]+y_shift] == agent2_pos) or ([chick1_pos[0]+x_shift, chick1_pos[1]+y_shift] == chick2_pos) or ([chick1_pos[0]+x_shift, chick1_pos[1]+y_shift] == agent1_pos):&amp;#10;            flag = True&amp;#10;            possiblemoves.remove(this_chick1_move)&amp;#10;        elif (abs(chick1_pos[0]+x_shift) &gt; .35):&amp;#10;            flag = True&amp;#10;            possiblemoves.remove(this_chick1_move)&amp;#10;        else:&amp;#10;            flag = False&amp;#10;    elif nchicks == 1:&amp;#10;        if ([chick1_pos[0]+x_shift, chick1_pos[1]+y_shift] == agent2_pos) or ([chick1_pos[0]+x_shift, chick1_pos[1]+y_shift] == agent1_pos):&amp;#10;            flag = True&amp;#10;            possiblemoves.remove('space')&amp;#10;            possiblemoves.remove(this_chick1_move)&amp;#10;        elif (abs(chick1_pos[0]+x_shift) &gt; .35):&amp;#10;            flag = True&amp;#10;            possiblemoves.remove(this_chick1_move)&amp;#10;        else:&amp;#10;            flag = False&amp;#10;&amp;#10;    &amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="if chick_timer.getTime()&gt;chick_jitter:&amp;#10;    if this_chick1_move != 'space':&amp;#10;        chick1.image = chick1_imgs[this_chick1_move]&amp;#10;    else:&amp;#10;        chick1.image = chick1_imgs['stay']&amp;#10;&amp;#10;    chick1_pos = [chick1_pos[0]+x_shift, chick1_pos[1]+y_shift]&amp;#10;    chick1.setPos(chick1_pos, log=True)&amp;#10;    thisExp.addData(f'chick1_action', this_chick1_move)&amp;#10;&amp;#10;    # store timing:&amp;#10;    chick_move_onset_time = globalClock.getTime() - trigger_time&amp;#10;    thisExp.addData('chick_move_onset', chick_move_onset_time)&amp;#10;    &amp;#10;    chick_move_since_round_start = globalClock.getTime() - round_start_time&amp;#10;    thisExp.addData('chick_move_onset_from_round_start', chick_move_since_round_start)&amp;#10;&amp;#10;    #print('chick1', out_x, out_y, possiblemoves, this_chick1_move)&amp;#10;    win.flip()&amp;#10;    core.wait(1)&amp;#10;&amp;#10;    chick1.image = chick1_imgs['down']&amp;#10;    win.flip()&amp;#10;    continueRoutine = False" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="if ((chick_timer.getTime() &gt; chick_jitter)) {&amp;#10;    if ((this_chick1_move !== &quot;space&quot;)) {&amp;#10;        chick1.image = chick1_imgs[this_chick1_move];&amp;#10;    } else {&amp;#10;        chick1.image = chick1_imgs[&quot;stay&quot;];&amp;#10;    }&amp;#10;    chick1_pos = [(chick1_pos[0] + x_shift), (chick1_pos[1] + y_shift)];&amp;#10;    chick1.setPos(chick1_pos, {&quot;log&quot;: true});&amp;#10;    psychoJS.experiment.addData(`chick1_action`, this_chick1_move);&amp;#10;    chick_move_onset_time = (globalClock.getTime() - trigger_time);&amp;#10;    psychoJS.experiment.addData(&quot;chick_move_onset&quot;, chick_move_onset_time);&amp;#10;    chick_move_since_round_start = (globalClock.getTime() - round_start_time);&amp;#10;    psychoJS.experiment.addData(&quot;chick_move_onset_from_round_start&quot;, chick_move_since_round_start);&amp;#10;    psychoJS.window.flip();&amp;#10;    core.wait(1);&amp;#10;    chick1.image = chick1_imgs[&quot;down&quot;];&amp;#10;    psychoJS.window.flip();&amp;#10;    continueRoutine = false;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
