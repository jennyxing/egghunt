        <Param val="trial_num_text = `${TrialCount} out of ${trials.nReps} trials`;&amp;#10;[out_x, out_y, possiblemoves] = convert_coords(agent2_pos[0], agent2_pos[1]);&amp;#10;flag = true;&amp;#10;while (flag) {&amp;#10;    this_agent2_move = np.random.choice(possiblemoves);&amp;#10;    [x_shift, y_shift] = convert_moves(this_agent2_move);&amp;#10;    if (([(agent2_pos[0] + x_shift), (agent2_pos[1] + y_shift)] === stag_pos)) {&amp;#10;        flag = true;&amp;#10;        possiblemoves.remove(this_agent2_move);&amp;#10;    } else {&amp;#10;        if (([(agent2_pos[0] + x_shift), (agent2_pos[1] + y_shift)] === agent1_pos)) {&amp;#10;            flag = true;&amp;#10;            possiblemoves.remove(this_agent2_move);&amp;#10;        } else {&amp;#10;            flag = false;&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="trial_num_text = f'{TrialCount} out of {trials.nReps} trials'&amp;#10;&amp;#10;# get grid coords and moves&amp;#10;out_x, out_y, possiblemoves = convert_coords(agent2_pos[0], agent2_pos[1])&amp;#10;&amp;#10;flag = True&amp;#10;while flag:&amp;#10;    this_agent2_move = np.random.choice(possiblemoves)&amp;#10;    x_shift, y_shift = convert_moves(this_agent2_move)&amp;#10;&amp;#10;    if ([agent2_pos[0]+x_shift, agent2_pos[1]+y_shift] == stag_pos):&amp;#10;        flag = True&amp;#10;        possiblemoves.remove(this_agent2_move)&amp;#10;    elif ([agent2_pos[0]+x_shift, agent2_pos[1]+y_shift] == agent1_pos):&amp;#10;        flag = True&amp;#10;        possiblemoves.remove(this_agent2_move)&amp;#10;    else:&amp;#10;        flag = False" valType="extendedCode" updates="constant" name="Begin Routine"/>
