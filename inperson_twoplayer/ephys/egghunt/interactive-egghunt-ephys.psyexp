  <Flow>
    <Routine name="start_exp"/>
    <Routine name="start_1"/>
    <Routine name="get_ready"/>
    <LoopInitiator loopType="TrialHandler" name="rounds">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'ntrials': 10}, {'ntrials': 11}, {'ntrials': 12}, {'ntrials': 13}, {'ntrials': 14}, {'ntrials': 15}, {'ntrials': 16}, {'ntrials': 17}, {'ntrials': 18}, {'ntrials': 19}, {'ntrials': 20}, {'ntrials': 10}, {'ntrials': 11}, {'ntrials': 12}, {'ntrials': 13}, {'ntrials': 14}, {'ntrials': 15}, {'ntrials': 16}, {'ntrials': 17}, {'ntrials': 18}, {'ntrials': 19}, {'ntrials': 20}, {'ntrials': 10}, {'ntrials': 11}, {'ntrials': 12}, {'ntrials': 13}, {'ntrials': 14}, {'ntrials': 15}, {'ntrials': 16}, {'ntrials': 17}, {'ntrials': 18}, {'ntrials': 19}, {'ntrials': 20}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="rounds.xlsx" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="random" valType="str"/>
      <Param name="nReps" updates="None" val="1" valType="num"/>
      <Param name="name" updates="None" val="rounds" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="p1_confirm"/>
    <Routine name="p2_confirm"/>
    <Routine name="start_round"/>
    <LoopInitiator loopType="TrialHandler" name="trials">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="None" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="ntrials" valType="num"/>
      <Param name="name" updates="None" val="trials" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="move_chick1"/>
    <LoopInitiator loopType="TrialHandler" name="player1_first">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="None" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="False" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="player1_turn" valType="num"/>
      <Param name="name" updates="None" val="player1_first" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="move_agent1"/>
    <Routine name="move_agent2"/>
    <LoopTerminator name="player1_first"/>
    <LoopInitiator loopType="TrialHandler" name="player2_first">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="None" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="False" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="player2_turn" valType="num"/>
      <Param name="name" updates="None" val="player2_first" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="move_agent2"/>
    <Routine name="move_agent1"/>
    <LoopTerminator name="player2_first"/>
    <Routine name="end_turns"/>
    <LoopTerminator name="trials"/>
    <Routine name="end_round"/>
    <LoopTerminator name="rounds"/>
    <Routine name="end_game"/>
  </Flow>
</PsychoPy2experiment>
