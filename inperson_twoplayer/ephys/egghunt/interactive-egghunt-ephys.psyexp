        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if ((Number.parseInt(expInfo[&quot;nchicks&quot;]) &gt;= 2)) {&amp;#10;    [out_x, out_y, possiblemoves] = convert_coords(chick2_pos[0], chick2_pos[1]);&amp;#10;    flag = true;&amp;#10;    while (flag) {&amp;#10;        this_stag_move = np.random.choice(possiblemoves);&amp;#10;        [x_shift, y_shift] = convert_moves(this_stag_move);&amp;#10;        if (((([(chick2_pos[0] + x_shift), (chick2_pos[1] + y_shift)] === agent2_pos) || ([(chick2_pos[0] + x_shift), (chick2_pos[1] + y_shift)] === chick1_pos)) || ([(chick2_pos[0] + x_shift), (chick2_pos[1] + y_shift)] === agent1_pos))) {&amp;#10;            flag = true;&amp;#10;            possiblemoves.remove(this_stag_move);&amp;#10;        } else {&amp;#10;            if ((Math.abs((chick2_pos[0] + x_shift)) &gt; 0.35)) {&amp;#10;                flag = true;&amp;#10;                possiblemoves.remove(this_stag_move);&amp;#10;            } else {&amp;#10;                flag = false;&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    if ((this_stag_move === &quot;right&quot;)) {&amp;#10;        chick2.flipHoriz = true;&amp;#10;    }&amp;#10;    if ((this_stag_move === &quot;left&quot;)) {&amp;#10;        chick2.flipHoriz = false;&amp;#10;    }&amp;#10;} else {&amp;#10;    console.log(&quot;no chick 2&quot;);&amp;#10;    continueRoutine = false;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="if int(expInfo['nchicks']) &gt;= 2:&amp;#10;    # get grid coords and moves&amp;#10;    out_x, out_y, possiblemoves = convert_coords(chick2_pos[0], chick2_pos[1])&amp;#10;&amp;#10;    flag = True&amp;#10;    while flag:&amp;#10;        this_stag_move = np.random.choice(possiblemoves)&amp;#10;        x_shift, y_shift = convert_moves(this_stag_move)&amp;#10;&amp;#10;        if ([chick2_pos[0]+x_shift, chick2_pos[1]+y_shift] == agent2_pos) or ([chick2_pos[0]+x_shift, chick2_pos[1]+y_shift] == chick1_pos) or ([chick2_pos[0]+x_shift, chick2_pos[1]+y_shift] == agent1_pos):&amp;#10;            flag = True&amp;#10;            possiblemoves.remove(this_stag_move)&amp;#10;        elif (abs(chick2_pos[0]+x_shift) &gt; .35):&amp;#10;            flag = True&amp;#10;            possiblemoves.remove(this_stag_move)&amp;#10;        else:&amp;#10;            flag = False&amp;#10;&amp;#10;    if this_stag_move == 'right':&amp;#10;        chick2.flipHoriz = True&amp;#10;&amp;#10;    if this_stag_move == 'left':&amp;#10;        chick2.flipHoriz = False&amp;#10;else:&amp;#10;    print('no chick 2')&amp;#10;    continueRoutine = False&amp;#10;    &amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="if int(expInfo['nchicks']) == 1:&amp;#10;    continueRoutine = False" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="if ((Number.parseInt(expInfo[&quot;nchicks&quot;]) === 1)) {&amp;#10;    continueRoutine = false;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="if ((Number.parseInt(expInfo[&quot;nchicks&quot;]) &gt;= 2)) {&amp;#10;    chick2_pos = [(chick2_pos[0] + x_shift), (chick2_pos[1] + y_shift)];&amp;#10;    chick2.setPos(chick2_pos, {&quot;log&quot;: true});&amp;#10;    console.log(&quot;chick2&quot;, out_x, out_y, possiblemoves, this_stag_move);&amp;#10;    psychoJS.window.flip();&amp;#10;    core.wait(1);&amp;#10;} else {&amp;#10;    continueRoutine = false;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="if int(expInfo['nchicks']) &gt;= 2:&amp;#10;    chick2_pos = [chick2_pos[0]+x_shift, chick2_pos[1]+y_shift]&amp;#10;    chick2.setPos(chick2_pos, log=True)&amp;#10;    print('chick2', out_x, out_y, possiblemoves, this_stag_move)&amp;#10;&amp;#10;    win.flip()&amp;#10;    core.wait(1)&amp;#10;else:&amp;#10;    continueRoutine = False" valType="extendedCode" updates="constant" name="End Routine"/>
