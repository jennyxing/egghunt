        <Param val="GridWorldComponents = [b_0_2, b_0_1, b_3_0, b_2_2, b_1_2, b_2_1, b_2_neg1, b_2_neg2, b_2_0, b_1_neg2, b_1_0, b_0_0, b_neg1_0, b_neg1_2, b_neg1_neg2, b_neg2_0, b_neg2_1, b_neg2_neg1, b_neg2_neg2, b_neg2_2, b_neg3_0, b_0_neg1, b_0_neg2, egg_left, egg_right];&amp;#10;for (var thisComponent, _pj_c = 0, _pj_a = GridWorldComponents, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    thisComponent = _pj_a[_pj_c];&amp;#10;    if ((&quot;setAutoDraw&quot; in thisComponent)) {&amp;#10;        thisComponent.setAutoDraw(false);&amp;#10;    }&amp;#10;}&amp;#10;AgentsComponents = [chick1];&amp;#10;if ((nchicks &gt;= 2)) {&amp;#10;    AgentsComponents += [chick2];&amp;#10;}&amp;#10;if ((nchicks &gt;= 3)) {&amp;#10;    AgentsComponents += [chick3];&amp;#10;}&amp;#10;for (var thisComponent, _pj_c = 0, _pj_a = AgentsComponents, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    thisComponent = _pj_a[_pj_c];&amp;#10;    if ((&quot;setAutoDraw&quot; in thisComponent)) {&amp;#10;        thisComponent.setAutoDraw(false);&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="GridWorldComponents = [b_0_2, b_0_1, b_3_0, b_2_2, b_1_2, b_2_1, b_2_neg1, b_2_neg2, b_2_0, b_1_neg2, b_1_0, b_0_0, b_neg1_0, b_neg1_2, b_neg1_neg2, b_neg2_0, b_neg2_1, b_neg2_neg1, b_neg2_neg2, b_neg2_2, b_neg3_0, b_0_neg1, b_0_neg2, egg_left, egg_right]&amp;#10;&amp;#10;for thisComponent in GridWorldComponents:&amp;#10;    if hasattr(thisComponent, &quot;setAutoDraw&quot;):&amp;#10;        thisComponent.setAutoDraw(False)&amp;#10;&amp;#10;AgentsComponents = [chick1] #agent1, agent2, &amp;#10;if nchicks &gt;= 2:&amp;#10;    AgentsComponents += [chick2]&amp;#10;&amp;#10;if nchicks &gt;= 3:&amp;#10;    AgentsComponents += [chick3]&amp;#10;    &amp;#10;for thisComponent in AgentsComponents:&amp;#10;    if hasattr(thisComponent, &quot;setAutoDraw&quot;):&amp;#10;        thisComponent.setAutoDraw(False)" valType="extendedCode" updates="constant" name="Begin Routine"/>
