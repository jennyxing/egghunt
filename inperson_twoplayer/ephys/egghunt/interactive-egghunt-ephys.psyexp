d_start&quot;, agent2_move_since_round_start);&amp;#10;                        psychoJS.window.flip();&amp;#10;                    } else {&amp;#10;                        this_agent2_move = &quot;null&quot;;&amp;#10;                        agent2.image = agent2_imgs[&quot;down&quot;];&amp;#10;                        agent2_move_onset_time = (globalClock.getTime() - trigger_time);&amp;#10;                        psychoJS.experiment.addData(&quot;agent2_move_onset&quot;, agent2_move_onset_time);&amp;#10;                        agent2_move_since_round_start = (globalClock.getTime() - round_start_time);&amp;#10;                        psychoJS.experiment.addData(&quot;agent2_move_onset_from_round_start&quot;, agent2_move_since_round_start);&amp;#10;                        psychoJS.window.flip();&amp;#10;                    }&amp;#10;                }&amp;#10;            }&amp;#10;        }&amp;#10;        agent2.setPos(agent2_pos, {&quot;log&quot;: true});&amp;#10;        agent2_indicator_text.setPos(agent2_pos, {&quot;log&quot;: true});&amp;#10;        if ((agent2_pos[0] &gt; 0.3)) {&amp;#10;            egg_right.setAutoDraw(false);&amp;#10;        }&amp;#10;        if ((agent2_pos[0] &lt; (- 0.3))) {&amp;#10;            egg_left.setAutoDraw(false);&amp;#10;        }&amp;#10;        psychoJS.window.flip();&amp;#10;        continueRoutine = false;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
