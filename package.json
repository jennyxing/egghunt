{
  "name": "egghunt-online",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "migrate": "npx knex migrate:latest",
    "migrate:down": "npx knex migrate:down",
    "migrate:rollback": "npx knex migrate:rollback",
    "seed": "npx knex seed:run",
    "watch-and-run-server": "tsc -w -p tsconfig.server.json & npx nodemon -r esm-wallaby server_build/server.js",
    "build:server": "tsc -p tsconfig.server.json",
    "start:server": "node -r esm-wallaby server_build/server.js",
    "start": "npm run build && npm run build:server && npm run start:server"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "boardgame.io": "^0.50.2",
    "dotenv": "^16.3.1",
    "esm-wallaby": "^3.2.26",
    "knex": "^2.5.1",
    "koa-body": "^6.0.1",
    "koa-static": "^5.0.0",
    "matchmaking": "^0.4.32",
    "mysql2": "^3.6.0",
    "react": "^18.2.0",
    "react-device-detect": "^2.2.3",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.10.0"
  },
  "devDependencies": {
    "@types/koa-static": "^4.0.2",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^3.1.0",
    "typescript": "^4.9.3",
    "vite": "^4.2.0"
  },
  "engines": {
    "node": "18.15.0",
    "npm": "9.5.0"
  }
}